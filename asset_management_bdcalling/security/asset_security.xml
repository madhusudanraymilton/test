<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- GROUPS                                                              -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->

        <!-- Module Category -->
        <record id="module_category_asset_management" model="ir.module.category">
            <field name="name">Asset Management</field>
            <field name="sequence">20</field>
        </record>

        <!-- Privileges -->
        <record id="privilege_asset_user" model="res.groups.privilege">
            <field name="name">Asset User</field>
            <field name="category_id" ref="module_category_asset_management"/>
        </record>

        <record id="privilege_asset_officer" model="res.groups.privilege">
            <field name="name">Asset Officer</field>
            <field name="category_id" ref="module_category_asset_management"/>
        </record>

        <record id="privilege_asset_manager" model="res.groups.privilege">
            <field name="name">Asset Manager</field>
            <field name="category_id" ref="module_category_asset_management"/>
        </record>

        <!-- Groups -->
        <record id="group_asset_user" model="res.groups">
            <field name="name">Asset User</field>
            <field name="privilege_id" ref="privilege_asset_user"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_asset_officer" model="res.groups">
            <field name="name">Asset Officer</field>
            <field name="privilege_id" ref="privilege_asset_officer"/>
            <field name="implied_ids" eval="[(4, ref('asset_management_bdcalling.group_asset_user'))]"/>
        </record>

        <record id="group_asset_manager" model="res.groups">
            <field name="name">Asset Manager</field>
            <field name="privilege_id" ref="privilege_asset_manager"/>
            <field name="implied_ids" eval="[(4, ref('asset_management_bdcalling.group_asset_officer'))]"/>
        </record>
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- RECORD RULES — Multi-company isolation                             -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->

        <!-- asset.asset -->
        <record id="rule_asset_asset_company" model="ir.rule">
            <field name="name">Asset: Multi-Company Rule</field>
            <field name="model_id" ref="model_asset_asset"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

        <!-- asset.category -->
        <record id="rule_asset_category_company" model="ir.rule">
            <field name="name">Asset Category: Multi-Company Rule</field>
            <field name="model_id" ref="model_asset_category"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

        <!-- asset.assignment -->
        <record id="rule_asset_assignment_company" model="ir.rule">
            <field name="name">Asset Assignment: Multi-Company Rule</field>
            <field name="model_id" ref="model_asset_assignment"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

        <!-- asset.history -->
        <record id="rule_asset_history_company" model="ir.rule">
            <field name="name">Asset History: Multi-Company Rule</field>
            <field name="model_id" ref="model_asset_history"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

        <!-- asset.depreciation.line -->
        <record id="rule_asset_depreciation_line_company" model="ir.rule">
            <field name="name">Asset Depreciation Line: Multi-Company Rule</field>
            <field name="model_id" ref="model_asset_depreciation_line"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

    </data>

</odoo>
