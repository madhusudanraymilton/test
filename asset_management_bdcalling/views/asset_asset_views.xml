<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form View ──────────────────────────────────────────────────── -->
    <record id="view_asset_asset_form" model="ir.ui.view">
        <field name="name">asset.asset.form</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <header>
                    <!-- Action Buttons -->
                    <button name="action_register" type="object" string="Register"
                            class="btn-primary"/>
                    <button name="action_unregister" type="object" string="Unregister"/>
                    <button name="action_assign" type="object" string="Assign" class="btn-primary"/>
                    <button name="action_return" type="object" string="Return"/>
                    <button name="action_scrap" type="object" string="Scrap" confirm="Are you sure you want to scrap this asset? This cannot be undone."/>
                    <button name="action_dispose" type="object" string="Dispose" confirm="Are you sure you want to dispose this asset? This cannot be undone."/>
                    <!-- Status Bar -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,available,assigned,scrapped,disposed"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger"
                            />
                    <div class="oe_title">
                        <label for="code" string="Asset Code"/>
                        <h2>
                            <field name="code" readonly="1" placeholder="Generated on registration"/>
                        </h2>
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Asset Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Asset Details">
                            <field name="product_id"/>
                            <field name="lot_id"
                                   domain="[('product_id', '=', product_id)]"/>
                            <field name="serial_number" readonly="1"/>
                            <field name="category_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Financial">
                            <field name="purchase_date"/>
                            <field name="registration_date" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="purchase_price"/>
                            <field name="residual_value" readonly="1"/>
                            <field name="location_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <!-- Tab 1: Assignment -->
                        <page string="Assignment" name="assignment">
                            <group>
                                <field name="current_employee_id" readonly="1"/>
                            </group>
                            <field name="assignment_ids" readonly="1">
                                <list string="Assignment History">
                                    <field name="assign_date"/>
                                    <field name="employee_id"/>
                                    <field name="condition_on_assign"/>
                                    <field name="return_date"/>
                                    <field name="condition_on_return"/>
                                    <field name="is_active"/>
                                    <field name="assigned_by"/>
                                </list>
                            </field>
                        </page>
                        <!-- Tab 2: Depreciation -->
                        <page string="Depreciation Schedule" name="depreciation">
                            <field name="depreciation_line_ids" readonly="1">
                                <list string="Depreciation Lines" decoration-success="move_posted_check == True">
                                    <field name="sequence" string="#"/>
                                    <field name="depreciation_date"/>
                                    <field name="amount" string="Amount"/>
                                    <field name="depreciated_value" string="Cumulative Dep."/>
                                    <field name="remaining_value" string="Book Value"/>
                                    <field name="move_check" string="Entry Created" widget="boolean_toggle"/>
                                    <field name="move_posted_check" string="Posted" widget="boolean_toggle"/>
                                    <field name="move_id" string="Journal Entry"/>
                                </list>
                            </field>
                        </page>
                        <!-- Tab 3: History -->
                        <page string="Lifecycle History" name="history">
                            <field name="history_ids" readonly="1">
                                <list string="History" create="0" edit="0" delete="0">
                                    <field name="event_date"/>
                                    <field name="event_type"/>
                                    <field name="old_state"/>
                                    <field name="new_state"/>
                                    <field name="employee_id"/>
                                    <field name="user_id"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                        <!-- Tab 4: Notes -->
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes about this asset..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── List View ──────────────────────────────────────────────────── -->
    <record id="view_asset_asset_list" model="ir.ui.view">
        <field name="name">asset.asset.list</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <list string="Assets" decoration-muted="state in ('scrapped','disposed')">
                <field name="code"/>
                <field name="name"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-info="state == 'assigned'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state in ('scrapped', 'disposed')"/>
                <field name="current_employee_id"/>
                <field name="purchase_price"/>
                <field name="residual_value"/>
                <field name="company_id" groups="base.group_multi_company" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ── Kanban View ────────────────────────────────────────────────── -->
    <record id="view_asset_asset_kanban" model="ir.ui.view">
        <field name="name">asset.asset.kanban</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="code"/>
                <field name="name"/>
                <field name="state"/>
                <field name="category_id"/>
                <field name="current_employee_id"/>
                <!-- <field name="color"/> -->
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click
                            #{record.state.raw_value == 'scrapped' || record.state.raw_value == 'disposed' ? 'border-danger' : ''}">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <small class="o_kanban_record_subtitle text-muted">
                                        <field name="code"/>
                                    </small>
                                </div>
                                <div class="o_kanban_record_top_right">
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'available'"
                                           decoration-info="state == 'assigned'"
                                           decoration-warning="state == 'draft'"
                                           decoration-danger="state in ('scrapped','disposed')"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div t-if="record.category_id.value">
                                    <i class="fa fa-tag me-1"/>
                                    <field name="category_id"/>
                                </div>
                                <div t-if="record.current_employee_id.value">
                                    <i class="fa fa-user me-1"/>
                                    <field name="current_employee_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

