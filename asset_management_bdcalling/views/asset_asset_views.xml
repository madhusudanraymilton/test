    <!-- ── Actions ────────────────────────────────────────────────────── -->
    <record id="action_asset_asset_all" model="ir.actions.act_window">
        <field name="name">All Assets</field>
        <field name="res_model">asset.asset</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Register your first asset</p>
            <p>Use the Register button to move a serial-tracked product from inventory into the asset register.</p>
        </field>
    </record>

