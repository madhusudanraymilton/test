<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_asset_form_inherit_custom" model="ir.ui.view">
        <field name="name">account.asset.form.inherit.custom</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@class='oe_title']/label[@name='model_name_label']" position="attributes">
                <attribute name="string">Asset Category</attribute>
            </xpath>

            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="fw-bold text-muted small">Asset Code:</span>
                    <field
                        name="asset_code"
                        class="fw-bold text-primary"
                        nolabel="1"
                        readonly="1"
                    />
                </div>
            </xpath>

            <xpath expr="//header/field[@name='state']" position="replace">

                <!-- Register: Draft → Available -->
                <button
                    name="action_register"
                    string="Register"
                    type="object"
                    class="btn-primary"
                    invisible="asset_lifecycle_state != 'draft'"
                />

                <!-- Unregister: Available → Draft -->
                <button
                    name="action_unregister"
                    string="Unregister"
                    type="object"
                    invisible="asset_lifecycle_state != 'available'"
                />
                <button 
                    name="action_assign"
                    type="object" 
                    string="Assign" 
                    class="btn-primary" 
                    invisible="asset_lifecycle_state != 'available'"/>
                <!-- Return: Assigned → Available  (also clears assignee) -->
                <!-- <button
                    name="action_return_asset"
                    string="Return"
                    type="object"
                    invisible="asset_lifecycle_state != 'assigned'"
                    confirm="Return this asset from the current assignee?"
                /> -->

                <!-- Scrap: any active state → Scrapped -->
                <button
                    name="action_scrap"
                    string="Scrap"
                    type="object"
                    class="btn-danger"
                    invisible="asset_lifecycle_state in ('scrapped', 'disposed')"
                    confirm="Mark this asset as scrapped? This action cannot be easily reversed."
                />

                

                <!-- Dispose: any non-disposed state → Disposed -->
                <button
                    name="action_dispose"
                    string="Dispose"
                    type="object"
                    class="btn-danger"
                    invisible="asset_lifecycle_state == 'disposed'"
                    confirm="Mark this asset as disposed? This action cannot be easily reversed."
                />
                <field
                    name="asset_lifecycle_state"
                    widget="statusbar"
                    statusbar_visible="draft,available,assigned,scrapped,disposed"
                    readonly="1"
                />
            </xpath>

            <xpath expr="//field[@name='name']" position="after">
                <!-- <group string="Asset Details" name="asset_details_group"> -->
                    <group>
                        <field
                            name="product_id"
                            options="{'no_create': True, 'no_open': False}"

                        />
                        <field name="available_lot_ids" invisible="1"/>
                        <field name="lot_id"
                            domain="[('id', 'in', available_lot_ids)]"/>
                    </group>
                    <!-- Empty right column — keeps layout balanced -->
                <!-- </group> -->
            </xpath>

<!-- 
            <xpath expr="//header/field[@name='state']" position="after">
                
            </xpath> -->
            
            

