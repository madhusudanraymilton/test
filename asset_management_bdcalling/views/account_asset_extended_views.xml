<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_asset_form_inherit_custom" model="ir.ui.view">
        <field name="name">account.asset.form.inherit.custom</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_form"/>
        <field name="arch" type="xml">

            <!-- ── 1. Relabel the model name label to "Asset Category" ─────── -->
            <xpath expr="//div[@class='oe_title']/label[@name='model_name_label']"
                   position="attributes">
                <attribute name="string">Asset Category</attribute>
            </xpath>

            <!-- ── 2. Asset Code badge above the title block ─────────────────
                 Only visible on real assets (not on category forms).         -->
            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="d-flex align-items-center gap-2 mb-2"
                     invisible="state == 'model'">
                    <span class="fw-bold text-muted small">Asset Code:</span>
                    <field name="code" nolabel="1" readonly="1"/>
                </div>
            </xpath>

            <!-- ── 3. Product + Serial fields after the Name field ───────────
                 Only on real assets, not on category forms.                  -->
            <xpath expr="//div//field[@name='name']" position="after">
                <group>
                    <label for="product_id" invisible="state == 'model'">
                        Product
                    </label>
                    <field name="product_id"
                        nolabel="1"
                        invisible="state == 'model'"/>

                    <field name="available_lot_ids" invisible="1"/>

                    <field name="vendor_bill_line_id"
                        domain="[('move_id.move_type', '=', 'in_invoice')]"/>

                    <!-- <label for="lot_id" invisible="state == 'model'">
                        Serial Number
                    </label> -->
                    <!-- <field name="lot_id"
                        nolabel="1"
                        domain="[('id', 'in', available_lot_ids)]"
                        invisible="state == 'model'"/> -->
                    <!-- <field name="lot_ids" widget="many2many_tags" nolabel="1" domain="[('id', 'in', available_lot_ids)]" invisible="state == 'model'"/> -->
                </group>
            </xpath>

            <!-- ── 4. Replace native state widget + validate button ──────────

                 BUTTON VISIBILITY RULES
                 ┌────────────────┬──────────────────────────────────────────┐
                 │ Button         │ invisible when                           │
                 ├────────────────┼──────────────────────────────────────────┤
                 │ Register       │ asset_state != 'draft'                   │
                 │ Unregister     │ asset_state != 'available'               │
                 │ Assign         │ asset_state != 'available'               │
                 │ Return         │ asset_state != 'assigned'                │
                 │ Scrap          │ asset_state not in available/assigned    │
                 │ Dispose        │ asset_state not in available/assigned    │
                 └────────────────┴──────────────────────────────────────────┘
                 All buttons hidden on category records (state == 'model').

                 The native state statusbar (draft/open/close) is kept
                 as-is by Odoo; we add our own AMS statusbar below it.       -->
            <xpath expr="//header/field[@name='state']" position="replace">

                <button name="action_register"
                        string="Register"
                        type="object"
                        class="btn-primary"
                        invisible="asset_state != 'draft' or state == 'model' or not is_auto_created"/>

                <button name="action_unregister"
                        string="Unregister"
                        type="object"
                        invisible="asset_state != 'available' or state == 'model'"/>
                
                <button name="action_auto_create_from_product_serials"
                    string="Auto-Create from All Serials"
                    type="object"
                    class="btn-secondary"
                    invisible="state == 'model' or not product_id or asset_state != 'draft' or is_auto_created"
                    confirm="Create one draft asset for every unregistered serial number of this product?"/>

                <button name="action_assign"
                        string="Assign"
                        type="object"
                        class="btn-primary"
                        invisible="asset_state != 'available' or state == 'model'"/>

                <button name="action_return"
                        string="Return"
                        type="object"
                        confirm="Return this asset from the current assignee?"
                        invisible="asset_state != 'assigned' or state == 'model'"/>

                <button name="action_scrap"
                        string="Scrap"
                        type="object"
                        class="btn-danger"
                        confirm="Mark this asset as scrapped? This cannot be easily reversed."
                        invisible="asset_state not in ('available', 'assigned') or state == 'model'"/>

                <button name="action_dispose"
                        string="Dispose"
                        type="object"
                        class="btn-danger"
                        confirm="Mark this asset as disposed? This cannot be easily reversed."
                        invisible="asset_state not in ('available', 'assigned') or state == 'model'"/>

                <!-- Native state bar (draft/open/close) — Odoo manages this -->
                <!-- <field name="state"
                       widget="statusbar"
                       statusbar_visible="draft,open,close"
                       readonly="1"
                       invisible="state == 'model'"/> -->

                <!-- AMS lifecycle state bar — we manage this -->
                <field name="asset_state"
                       widget="statusbar"
                       statusbar_visible="draft,available,assigned,returned,scrapped,disposed"
                       readonly="1"
                       invisible="state == 'model'"/>

            </xpath>
            <xpath expr="//button[@name='action_save_model']" position="replace"/>
            <xpath expr="//button[@name='set_to_cancelled']" position="replace"/>

            <!-- ── 5. Remove native Validate / Confirm Asset button ──────── -->
            <xpath expr="//header//button[@name='validate']" position="replace"/>

            <!-- ── 6. Rename model_id column label to "Asset Category" ───── -->
            <xpath expr="//page[@name='main_page']//group//group[@name='asset_values']//field[@name='model_id']"
                   position="attributes">
                <attribute name="string">Asset Category</attribute>
            </xpath>

            <!-- ── 7. Remove asset_group_id from the standard info page ──── -->
            <xpath expr="//page[@name='main_page']//group//group[@name='asset_values']//field[@name='asset_group_id']"
                   position="replace"/>

            <!-- ── 8. AMS tabs (appended after the native related_items tab) -->
            <xpath expr="//page[@name='related_items']" position="replace">

                <!-- ── Assignment Tab ──────────────────────────────────────── -->
                <page string="Assignment" name="ams_assignment"
                      invisible="state == 'model'">
                    <group>
                        <field name="current_employee_id" readonly="1"/>
                    </group>
                    <field name="assignment_ids">
                        <list string="Assignment History">
                            <field name="assign_date"/>
                            <field name="employee_id"/>
                            <field name="condition_on_assign"/>
                            <field name="return_date"/>
                            <field name="condition_on_return"/>
                            <field name="is_active"
                                   widget="boolean_toggle"
                                   readonly="1"/>
                            <field name="assigned_by"/>
                        </list>
                    </field>
                </page>
                <!-- <xpath expr="//page[@name='related_items']" position="replace"/> -->

                <!-- ── Lifecycle History Tab (immutable audit log) ──────────── -->
                <page string="Lifecycle History" name="ams_history"
                      invisible="state == 'model'">
                    <field name="history_ids">
                        <list string="History"
                              create="0" edit="0" delete="0">
                            <field name="event_date"/>
                            <field name="event_type"/>
                            <field name="old_state"/>
                            <field name="new_state"/>
                            <field name="employee_id"/>
                            <field name="user_id"/>
                            <field name="description"/>
                        </list>
                    </field>
                </page>

                <!-- ── AMS Details Tab ───────────────────────────────────────
                     Shows AMS-specific fields that are not part of the native
                     accounting pages (product, serial, purchase info, notes). -->
                <!-- <page string="Asset Details" name="ams_details"
                      invisible="state == 'model'">
                    <group>
                        <group string="Identification">
                            <field name="purchase_date"/>
                            <field name="registration_date"/>
                            <field name="purchase_price"/>
                            <field name="location_id" readonly="1"/>
                        </group>
                        <group string="Status">
                            <field name="asset_state" readonly="1"/>
                            <field name="current_employee_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes"
                               nolabel="1"
                               colspan="2"
                               placeholder="Internal notes about this asset…"/>
                    </group>
                </page> -->
            </xpath>
        </field>
    </record>


    <record id="view_account_asset_tree_inherit_custom" model="ir.ui.view">
        <field name="name">account.asset.tree.inherit.custom</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_tree"/>
        <field name="arch" type="xml">

            <!-- ✅ 1. Add Product after Name -->
            <!-- <xpath expr="//field[@name='name']" position="after">
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="asset_state"/>
            </xpath> -->
            <xpath expr="//list" position="replace">
                <list string="Assets">

                    <field name="name"/>
                    <field name="asset_properties"/>
                    <field name="acquisition_date"/>
                    <field name="original_value"/>
                    <field name="method"/>
                    <field name="book_value"/>
                    <field name="value_residual" widget="monetary"/>
                    <field name="account_asset_id"/>
                    <field name="account_depreciation_id"/>
                    <field name="account_depreciation_expense_id"/>
                    <field name="analytic_distribution" widget="analytic_distribution"
                        groups="analytic.group_analytic_accounting"/>
                    <field name="currency_id" groups="base.group_multi_currency"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="parent_id"/>
                    <field name="state"/>
                    <field name="activity_exception_decoration" widget="activity_exception"/>
                    <field name="activity_ids" widget="list_activity"/>

                </list>
            </xpath>

            <!-- ✅ 2. Add your custom asset_state -->
            <xpath expr="//field[@name='state']" position="replace">
                <field name="asset_state"/>
            </xpath>

            <!-- ✅ 3. Optional: Hide native state -->
            <!-- <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath> -->

            <!-- ✅ 4. Update decorations (IMPORTANT) -->
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-info">asset_state == 'draft'</attribute>
                <attribute name="decoration-success">asset_state == 'available'</attribute>
                <attribute name="decoration-warning">asset_state == 'assigned'</attribute>
                <attribute name="decoration-danger">asset_state in ('scrapped','disposed')</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_account_asset_search_inherit_assignment" model="ir.ui.view">
        <field name="name">account.asset.search.inherit.assignment</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_search"/>
        <field name="arch" type="xml">

            <!-- 1️⃣ Add fields into search -->
            <xpath expr="//search/field[last()]" position="after">
                <field name="current_employee_id"/>
                <field name="code"/>
                <field name="lot_id"/>
            </xpath>

            <!-- 2️⃣ Add custom filters -->
            <xpath expr="//search" position="inside">
                <separator string="Asset Status"/>

                <filter string="Available"
                        name="filter_available"
                        domain="[('asset_state', '=', 'available')]"/>

                <filter string="Assigned"
                        name="filter_assigned"
                        domain="[('asset_state', '=', 'assigned')]"/>

                <filter string="Returned"
                        name="filter_returned"
                        domain="[('asset_state', '=', 'returned')]"/>

                <filter string="Draft"
                        name="filter_draft"
                        domain="[('asset_state', '=', 'draft')]"/>
            </xpath>

            <!-- 3️⃣ Add group by options -->
            <xpath expr="//group" position="inside">
                <filter string="Employee"
                        name="group_by_employee"
                        context="{'group_by': 'current_employee_id'}"/>

                <filter string="State"
                        name="group_by_state"
                        context="{'group_by': 'asset_state'}"/>

                <filter string="Serial Number"
                        name="group_by_lot"
                        context="{'group_by': 'lot_id'}"/>
                
            </xpath>

        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ACTIONS
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- All Assets: show only AMS-managed records (those with a serial number) -->
    <record id="account_asset.action_account_asset_form" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="view_mode">kanban,list,form</field>
        <!-- <field name="domain">[('lot_id', '!=', False)]</field> -->
        <field name="domain">[
           
            ('state', '!=', 'model')
        ]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No registered assets yet</p>
            <p>Use the <strong>Register</strong> button on a draft asset to activate it.</p>
        </field>
    </record>

    <!-- Asset Categories: unchanged (shows records where state='model') -->
    <record id="account_asset.action_account_asset_model_form" model="ir.actions.act_window">
        <field name="name">Asset Categories</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

















<!-- # -*- coding: utf-8 -*-
from odoo import models, fields, api, _
from odoo.exceptions import UserError
import logging

_logger = logging.getLogger(__name__)


class AccountAssetExtended(models.Model):
    _inherit = 'account.asset'

    # =========================================================================
    # AMS LIFECYCLE STATE
    # Completely separate from the native accounting state (draft/open/close).
    # The native `state` field is NEVER overridden — Odoo manages it internally.
    # =========================================================================
    asset_state = fields.Selection(
        selection=[
            ('draft',     'Draft'),
            ('available', 'Available'),
            ('assigned',  'Assigned'),
            ('returned',  'Returned'),
            ('scrapped',  'Scrapped'),
            ('disposed',  'Disposed'),
        ],
        string='Asset Status',
        default='draft',
        required=True,
        tracking=True,
        copy=False,
        index=True,
    )

    # =========================================================================
    # IDENTITY
    # =========================================================================
    code = fields.Char(
        string='Asset Code',
        readonly=True,
        copy=False,
        index=True,
    )

    # =========================================================================
    # PRODUCT & SERIAL LINKAGE
    # =========================================================================
    
    product_id = fields.Many2one(
        'product.product',
        string='Product',
        tracking=True,
        domain="[('is_asset', '=', True)]",
        ondelete='restrict',
    )

    lot_id = fields.Many2one(
        'stock.lot',
        string='Serial Number',
        tracking=True,
        domain="[('id', 'in', available_lot_ids)]",
        ondelete='restrict',
    )

    available_lot_ids = fields.Many2many(
        'stock.lot',
        string='Available Serials',
        compute='_compute_available_lot_ids',
        readonly=True,
    )

    # =========================================================================
    # DATES & FINANCIALS
    # purchase_price  = AMS display / input field
    # original_value  = native field written before validate()
    # value_residual  = native computed net book value
    # =========================================================================
    purchase_date     = fields.Date(string='Purchase Date', tracking=True)
    registration_date = fields.Date(string='Registration Date', readonly=True)
    purchase_price    = fields.Monetary(
        string='Purchase Price',
        currency_field='currency_id',
        tracking=True,
    )
    currency_id = fields.Many2one(
        'res.currency',
        string='Currency',
        required=True,
        default=lambda self: self.env.company.currency_id,
    )

    # =========================================================================
    # LOCATION & ASSIGNMENT
    # =========================================================================
    location_id = fields.Many2one(
        'stock.location',
        string='Asset Location',
    )
    current_employee_id = fields.Many2one(
        'hr.employee',
        string='Assigned To',
        tracking=True,
        domain="[('company_id', '=', company_id)]",
    )

    # =========================================================================
    # RELATIONAL LINES
    # =========================================================================
    assignment_ids = fields.One2many(
        'asset.assignment',
        'asset_id',
        string='Assignment History',
    )
    history_ids = fields.One2many(
        'asset.history',
        'asset_id',
        string='Lifecycle History',
    )
    notes = fields.Text(string='Notes')

    # =========================================================================
    # SQL CONSTRAINTS
    # =========================================================================
    _sql_constraints = [
        (
            'lot_unique',
            'UNIQUE(lot_id)',
            'A serial number can only be registered as one asset.',
        ),
        (
            'code_unique',
            'UNIQUE(code)',
            'Asset code must be globally unique.',
        ),
    ]

    # =========================================================================
    # COMPUTE METHODS
    # =========================================================================

    @api.depends('product_id')
    def _compute_available_lot_ids(self):
        """
        Returns lots that are NOT locked by any non-draft AMS asset.
        Uses sudo() when searching account.asset so the native multi-company
        record rule does not incorrectly exclude locked lots from other companies
        (we want a globally consistent lock check).
        """
        locked_lots = self.env['account.asset'].sudo().search([
            ('lot_id',      '!=', False),
            ('asset_state', 'not in', ['draft']),
            ('id',          'not in', self.ids),
        ]).mapped('lot_id')

        for rec in self:
            domain = (
                [('product_id', '=', rec.product_id.id)]
                if rec.product_id else []
            )
            product_lots = self.env['stock.lot'].search(domain)
            rec.available_lot_ids = product_lots - locked_lots

    # =========================================================================
    # ORM OVERRIDES
    # =========================================================================

    @api.model_create_multi
    def create(self, vals_list):
        for vals in vals_list:
            # Generate AMS code only for real asset records (not categories).
            # Category records have no lot_id.
            if not vals.get('code') and vals.get('lot_id'):
                vals['code'] = (
                    self.env['ir.sequence'].next_by_code('account.asset.code')
                    or '/'
                )
        return super().create(vals_list)

    # =========================================================================
    # ACTION BUTTONS
    # =========================================================================

    def action_register(self):
        """
        Opens the register wizard.
        State transition (draft → available) is handled entirely by the wizard
        after it calls validate() to generate the native depreciation board.
        """
        self.ensure_one()
        if self.asset_state != 'draft':
            raise UserError(_(
                'Asset "%s" has already been registered (current status: %s).'
            ) % (self.code or self.name, self.asset_state))
        if not self.product_id or not self.lot_id:
            raise UserError(_(
                'Please set a Product and Serial Number before registering.'
            ))
        return {
            'type':      'ir.actions.act_window',
            'name':      _('Register Asset'),
            'res_model': 'asset.register.wizard',
            'view_mode': 'form',
            'target':    'new',
            'context': {
                'default_asset_id':       self.id,
                'default_lot_id':         self.lot_id.id,
                'default_category_id':    self.model_id.id,
                'default_purchase_price': self.purchase_price or 0.0,
            },
        }

    def action_unregister(self):
        """Opens the unregister wizard (reverses stock move, resets to draft)."""
        self.ensure_one()
        if self.asset_state != 'available':
            raise UserError(_(
                'Only assets in "Available" status can be unregistered. '
                'Current status: %s'
            ) % self.asset_state)
        return {
            'type':      'ir.actions.act_window',
            'name':      _('Unregister Asset'),
            'res_model': 'asset.unregister.wizard',
            'view_mode': 'form',
            'target':    'new',
            'context': {'default_asset_id': self.id},
        }

    def action_assign(self):
        """Opens the assign wizard (available → assigned)."""
        self.ensure_one()
        if self.asset_state != 'available':
            raise UserError(_(
                'Only assets in "Available" status can be assigned. '
                'Current status: %s'
            ) % self.asset_state)
        return {
            'type':      'ir.actions.act_window',
            'name':      _('Assign Asset'),
            'res_model': 'asset.assign.wizard',
            'view_mode': 'form',
            'target':    'new',
            'context': {'default_asset_id': self.id},
        }

    def action_return(self):
        """Opens the return wizard (assigned → available)."""
        self.ensure_one()
        if self.asset_state != 'assigned':
            raise UserError(_(
                'Only assets in "Assigned" status can be returned. '
                'Current status: %s'
            ) % self.asset_state)
        return {
            'type':      'ir.actions.act_window',
            'name':      _('Return Asset'),
            'res_model': 'asset.return.wizard',
            'view_mode': 'form',
            'target':    'new',
            'context': {'default_asset_id': self.id},
        }

    def action_scrap(self):
        """Available or Assigned → Scrapped."""
        self.ensure_one()
        if self.asset_state not in ('available', 'assigned'):
            raise UserError(_(
                'Only Available or Assigned assets can be scrapped. '
                'Current status: %s'
            ) % self.asset_state)
        old_state = self.asset_state
        self.write({'asset_state': 'scrapped', 'current_employee_id': False})
        self._log_history(
            event_type='scrap',
            old_state=old_state,
            new_state='scrapped',
            description=_('Asset scrapped by %s') % self.env.user.name,
        )

    def action_dispose(self):
        """Available or Assigned → Disposed."""
        self.ensure_one()
        if self.asset_state not in ('available', 'assigned'):
            raise UserError(_(
                'Only Available or Assigned assets can be disposed. '
                'Current status: %s'
            ) % self.asset_state)
        old_state = self.asset_state
        self.write({'asset_state': 'disposed', 'current_employee_id': False})
        self._log_history(
            event_type='dispose',
            old_state=old_state,
            new_state='disposed',
            description=_('Asset disposed by %s') % self.env.user.name,
        )

    # =========================================================================
    # HISTORY LOGGING
    # =========================================================================

    def _log_history(self, event_type, old_state=None, new_state=None,
                     employee_id=None, description=None, metadata=None):
        """Append an immutable audit record for every AMS lifecycle transition."""
        self.env['asset.history'].sudo().create({
            'asset_id':    self.id,
            'event_type':  event_type,
            'event_date':  fields.Datetime.now(),
            'old_state':   old_state or '',
            'new_state':   new_state or self.asset_state,
            'employee_id': employee_id,
            'user_id':     self.env.uid,
            'description': description or _(
                'State changed: %s → %s'
            ) % (old_state, new_state),
            'metadata':    metadata or {},
            'company_id':  self.company_id.id,
        })

    # =========================================================================
    # DASHBOARD DATA
    # =========================================================================

    @api.model
    def get_dashboard_data(self):
        """Called by the OWL AssetDashboard component."""
        company_ids = self.env.companies.ids

        # AMS assets are identified by lot_id being set.
        # sudo() is used so the multi-company rule does not silently hide
        # assets from companies the user can switch to.
        assets = self.sudo().search([
            ('lot_id',     '!=', False),
            ('company_id', 'in', company_ids),
        ])

        total             = len(assets)
        available         = sum(1 for a in assets if a.asset_state == 'available')
        assigned          = sum(1 for a in assets if a.asset_state == 'assigned')
        scrapped_disposed = sum(
            1 for a in assets if a.asset_state in ('scrapped', 'disposed')
        )

        # Native fields: original_value (set before validate), value_residual (computed)
        total_value       = sum(assets.mapped('original_value'))
        net_book_value    = sum(assets.mapped('value_residual'))
        total_depreciated = total_value - net_book_value

        # Pending draft depreciation moves due today or earlier
        pending_depreciation = self.env['account.move'].sudo().search_count([
            ('asset_id', 'in', assets.ids),
            ('state',    '=', 'draft'),
            ('date',     '<=', fields.Date.today()),
        ])

        # Category breakdown by native model_id
        category_data = {}
        for asset in assets:
            cat = asset.model_id.name or _('Uncategorised')
            category_data[cat] = category_data.get(cat, 0) + 1

        # Last 10 assignments
        recent = self.env['asset.assignment'].sudo().search(
            [('company_id', 'in', company_ids)],
            order='assign_date desc',
            limit=10,
        )
        recent_assignments = [
            {
                'id':         a.id,
                'asset':      a.asset_id.name or '',
                'asset_code': a.asset_id.code or '',
                'employee':   a.employee_id.name or '',
                'date':       str(a.assign_date) if a.assign_date else '',
                'is_active':  a.is_active,
            }
            for a in recent
        ]

        return {
            'total':                total,
            'available':            available,
            'assigned':             assigned,
            'scrapped_disposed':    scrapped_disposed,
