            <!-- =============================================================
                 4.  LIFECYCLE HISTORY PAGE  — full assignment / return audit log
                 ============================================================= -->
            <xpath expr="//page[@name='related_items']" position="after">
                <page name="lifecycle_history_page" string="Lifecycle History">

                    <field
                        name="assignment_ids"
                        nolabel="1"
                        readonly="1"
                    >
                        <list
                            string="Assignment History"
                            create="false"
                            delete="false"
                            editable="false"
                            decoration-success="status == 'returned'"
                            decoration-info="status == 'active'"
                        >
                            <field name="assign_date" string="Assigned On"/>
                            <field name="employee_id" string="Employee"
                                   widget="many2one_avatar_employee"/>
                            <field name="department_id" string="Department"
                                   optional="show"/>
                            <field name="job_id" string="Job Position"
                                   optional="show"/>
                            <field name="return_date" string="Returned On"/>
                            <field name="duration_days" string="Days Held"
                                   optional="show"/>
                            <field name="status" string="Status"
                                   widget="badge"
                                   decoration-success="status == 'returned'"
                                   decoration-info="status == 'active'"/>
                            <field name="assigned_by_id" string="Assigned By"
                                   optional="show"/>
                            <field name="notes" string="Notes"
                                   optional="show"/>
                        </list>
                    </field>

                    <!-- Guard message when history is empty -->
                    <div
                        class="alert alert-info"
                        role="alert"
                        invisible="assignment_ids"
                    >
                        <i class="fa fa-history me-1"/>
                        No assignment history found for this asset yet.
                    </div>

                </page>
            </xpath>

        </field>
    </record>
     <!-- Action -->
    <record id="account_asset.action_account_asset_model_form" model="ir.actions.act_window">
        <field name="name">Asset Categories</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_account_asset_form_inherit_custom"/>
    </record>

    <record id="action_account_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">account.asset</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>