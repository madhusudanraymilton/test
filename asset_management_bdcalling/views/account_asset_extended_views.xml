<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_asset_form_inherit_custom" model="ir.ui.view">
        <field name="name">account.asset.form.inherit.custom</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@class='oe_title']/label[@name='model_name_label']" position="attributes">
                <attribute name="string">Asset Category</attribute>
            </xpath>

            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="fw-bold text-muted small" invisible="state == 'model'">Asset Code:</span>
                    <field
                        name="code"
                        nolabel="1"
                        readonly="1"
                        invisible="state == 'model'"
                    />
                </div>
            </xpath>

            <xpath expr="//div//field[@name='name']" position="after">
                <label for="product_id" invisible="state == 'model'">Product</label>
                <field name="product_id" string="Product" nolabel="1" invisible="state == 'model'"/>
                <field name="available_lot_ids" invisible="1"/>
                <label for="lot_id" invisible="state == 'model'">Serial Number</label>
                <field name="lot_id"
                    domain="[('id', 'in', available_lot_ids)]" string="Serial Number" invisible="state == 'model'"/>
            </xpath>

            <xpath expr="//header/field[@name='state']" position="replace">

                <!-- Register: Draft → Available -->
                <button
                    name="action_register"
                    string="Register"
                    type="object"
                    class="btn-primary"
                    invisible="state == 'model'"
                />

                <!-- Unregister: Available → Draft -->
                <button
                    name="action_unregister"
                    string="Unregister"
                    type="object"
                    invisible="state == 'model'"
                />
                <!-- Assign: Available → Assigned -->
                <button
                    name="action_assign"
                    string="Assign"
                    type="object"
                    invisible="state == 'model'"
                />

                <!-- Return: Assigned → Available  (also clears assignee) -->
                <button
                    name="action_return"
                    string="Return"
                    type="object"
                    confirm="Return this asset from the current assignee?"
                    invisible="state == 'model'"
                />

                <!-- Scrap: any active state → Scrapped -->
                <button
                    name="action_scrap"
                    string="Scrap"
                    type="object"
                    class="btn-danger"
                    confirm="Mark this asset as scrapped? This action cannot be easily reversed."
                    invisible="state == 'model'"
                />

                <!-- Dispose: any non-disposed state → Disposed -->
                <button
                    name="action_dispose"
                    string="Dispose"
                    type="object"
                    class="btn-danger"
                    confirm="Mark this asset as disposed? This action cannot be easily reversed."
                    invisible="state == 'model'"
                />
                <field
                    name="state"
                    widget="statusbar"
                    statusbar_visible="draft,available,assigned,scrapped,disposed"
                    readonly="1"
                    invisible="state == 'model'"
                />
            </xpath>

            <xpath expr="//page[@name='main_page']//group//group[@name='asset_values']//field[@name='model_id']" position='attributes'>
                <attribute name="string">Asset Category</attribute>
            </xpath>

             <xpath expr="//page[@name='main_page']//group//group[@name='asset_values']//field[@name='asset_group_id']" position='replace'/>
             <xpath expr="//header//button[@name='validate']" position='replace'/>
             <xpath expr="//page[@name='related_items']" position='after'>
                <page string="Assignment" name="assignment">
                    <group>
                        <field name="current_employee_id" readonly="1"/>
                    </group>
                    <field name="assignment_ids">
                        <list string="Assignment History">
                            <field name="assign_date"/>
                            <field name="employee_id"/>
                            <field name="condition_on_assign"/>
                            <field name="return_date"/>
                            <field name="condition_on_return"/>
                            <field name="is_active"/>
                            <field name="assigned_by"/>
                        </list>
                    </field>
                </page>

                <page string="Lifecycle History" name="history">
                    <field name="history_ids">
                        <list string="History" create="0" edit="0" delete="0">
                            <field name="event_date"/>
                            <field name="event_type"/>
                            <field name="old_state"/>
                            <field name="new_state"/>
                            <field name="employee_id"/>
                            <field name="user_id"/>
                            <field name="description"/>
                        </list>
                    </field>
                </page>
            </xpath>
        
