<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_asset_return_wizard_form" model="ir.ui.view">
        <field name="name">asset.return.wizard.form</field>
        <field name="model">asset.return.wizard</field>
        <field name="arch" type="xml">
            <form string="Return Asset">
                <sheet>
                    <group>
                        <field name="asset_id" readonly="1"/>
                        <field name="return_date"/>
                        <field name="condition_on_return"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" colspan="2"
                               placeholder="Optional notes about this return..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_return" type="object"
                            string="Confirm Return" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
