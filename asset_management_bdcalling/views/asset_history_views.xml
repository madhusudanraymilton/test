<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List View (read-only audit log) ───────────────────────────── -->
    <record id="view_asset_history_list" model="ir.ui.view">
        <field name="name">asset.history.list</field>
        <field name="model">asset.history</field>
        <field name="arch" type="xml">
            <list string="Asset History" create="0" edit="0" delete="0"
                  decoration-info="event_type == 'assign'"
                  decoration-success="event_type in ('register', 'return')"
                  decoration-warning="event_type == 'unregister'"
                  decoration-danger="event_type in ('scrap', 'dispose')">
                <field name="event_date"/>
                <field name="asset_id"/>
                <field name="event_type" widget="badge"
                       decoration-success="event_type in ('register','return')"
                       decoration-info="event_type == 'assign'"
                       decoration-warning="event_type in ('unregister','depreciate')"
                       decoration-danger="event_type in ('scrap','dispose')"/>
                <field name="old_state"/>
                <field name="new_state"/>
                <field name="employee_id"/>
                <field name="user_id"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- ── Search View ────────────────────────────────────────────────── -->
    <record id="view_asset_history_search" model="ir.ui.view">
        <field name="name">asset.history.search</field>
        <field name="model">asset.history</field>
        <field name="arch" type="xml">
            <search string="Asset History">
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="user_id"/>
                <field name="serial_number" string="Serial Number"/>
                
                <filter string="Registered" name="filter_register"
                        domain="[('event_type', '=', 'register')]"/>
                <filter string="Register Events" name="filter_register"
                        domain="[('event_type', '=', 'register')]"/>
                <filter string="Assign Events" name="filter_assign"
                        domain="[('event_type', '=', 'assign')]"/>
                <filter string="Return Events" name="filter_return"
                        domain="[('event_type', '=', 'return')]"/>
                <filter string="Depreciation Events" name="filter_depreciate"
                        domain="[('event_type', '=', 'depreciate')]"/>
                
                <filter string="Asset" name="group_asset"
                        context="{'group_by': 'asset_id'}"/>
                <filter string="Event Type" name="group_event_type"
                        context="{'group_by': 'event_type'}"/>
                <filter string="User" name="group_user"
                        context="{'group_by': 'user_id'}"/>
                <filter string="Serial Number" name="group_by_serial_number"
                        context="{'group_by': 'serial_number'}"/>
             
            </search>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────── -->
    <record id="action_asset_history" model="ir.actions.act_window">
        <field name="name">Asset History</field>
        <field name="res_model">asset.history</field>
        <field name="view_mode">list</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No history yet</p>
            <p>Asset lifecycle events will appear here once assets are registered.</p>
        </field>
    </record>

</odoo>
