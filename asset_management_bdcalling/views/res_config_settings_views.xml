<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <record id="res_config_settings_view_form_asset" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.asset.management</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block" data-string="Asset Management">
                    <h2>Asset Management</h2>

                    <div class="row mt16 o_settings_container">

                        <!-- Default Asset Location -->
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="asset_location_id"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="asset_location_id"/>
                                <div class="text-muted">
                                    Default stock location where registered assets are moved.
                                </div>
                            </div>
                        </div>

                        <!-- Auto Return on Employee Archive -->
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="auto_return_on_employee_archive"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="auto_return_on_employee_archive"/>
                                <div class="text-muted">
                                    Automatically return assigned assets when an employee is archived.
                                </div>
                            </div>
                        </div>

                        <!-- Allow Future Assignment Date -->
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="asset_assign_date_future_allowed"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="asset_assign_date_future_allowed"/>
                                <div class="text-muted">
                                    Allow assignment dates in the future.
                                </div>
                            </div>
                        </div>

                    </div>
                
                </div>
            </xpath>
        </field>
    </record>

    <record id="action_asset_settings" model="ir.actions.act_window">
    <field name="name">Asset Settings</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">res.config.settings</field>
    <field name="view_mode">form</field>
    <field name="view_id" ref="res_config_settings_view_form_asset"/> <!-- your inherited view -->
    <field name="target">current</field>
    <field name="context">{'module': 'asset_management_bdcalling', 'bin_size': False}</field>
</record>
</odoo>