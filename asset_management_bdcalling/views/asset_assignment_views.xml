<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form View ──────────────────────────────────────────────────── -->
    <record id="view_asset_assignment_form" model="ir.ui.view">
        <field name="name">asset.assignment.form</field>
        <field name="model">asset.assignment</field>
        <field name="arch" type="xml">
            <form string="Asset Assignment" create="0">
                <sheet>
                    <group>
                        <group string="Assignment">
                            <field name="asset_id" readonly="1"/>
                            <field name="employee_id"/>
                            <field name="assign_date"/>
                            <field name="assigned_by"/>
                            <field name="condition_on_assign"/>
                            <field name="is_active" readonly="1"/>
                        </group>
                        <group string="Return">
                            <field name="return_date"/>
                            <field name="returned_by"/>
                            <field name="condition_on_return"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── List View ──────────────────────────────────────────────────── -->
    <record id="view_asset_assignment_list" model="ir.ui.view">
        <field name="name">asset.assignment.list</field>
        <field name="model">asset.assignment</field>
        <field name="arch" type="xml">
            <list string="Asset Assignments" create="0"
                  decoration-success="is_active == True"
                  decoration-muted="is_active == False">
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="assign_date"/>
                <field name="condition_on_assign"/>
                <field name="return_date"/>
                <field name="condition_on_return"/>
                <field name="is_active" widget="boolean_toggle" readonly="1"/>
                <field name="assigned_by"/>
            </list>
        </field>
    </record>

    <!-- ── Search View ──────────────────────────────────────────────────── -->
    <record id="view_asset_assignment_search" model="ir.ui.view">
        <field name="name">asset.assignment.search</field>
        <field name="model">asset.assignment</field>
        <field name="arch" type="xml">
            <search string="Assignments">
                <field name="asset_id"/>
                <field name="employee_id"/>
                <filter string="Currently Assigned" name="filter_active"
                        domain="[('is_active', '=', True)]"/>
                <filter string="Returned" name="filter_returned"
                        domain="[('is_active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="Asset" name="group_asset"
                            context="{'group_by': 'asset_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────── -->
    <record id="action_asset_assignment" model="ir.actions.act_window">
        <field name="name">Asset Assignments</field>
        <field name="res_model">asset.assignment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
    </record>

</odoo>
