<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════════
         asset.assignment — Form View
         Read-only: assignments are created/closed exclusively through wizards.
         ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_asset_assignment_form" model="ir.ui.view">
        <field name="name">asset.assignment.form</field>
        <field name="model">asset.assignment</field>
        <field name="arch" type="xml">
            <form string="Asset Assignment" create="0">
                <!-- <header>
                    
                    <field name="is_active"
                           widget="badge"
                           readonly="1"
                           decoration-success="is_active == True"
                           decoration-secondary="is_active == False"
                           nolabel="1"/>
                </header> -->

                <sheet>
                    <!-- ── Smart buttons ───────────────────────────────── -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_asset"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-cube"
                                string="Asset"/>
                    </div>

                    <!-- ── Active banner ───────────────────────────────── -->
                    <!-- <div class="alert alert-success d-flex align-items-center gap-2 mb-0"
                         role="alert"
                         invisible="not is_active">
                        <i class="fa fa-check-circle fa-lg"/>
                        <span>This assignment is currently <strong>active</strong>.</span>
                    </div>
                    <div class="alert alert-secondary d-flex align-items-center gap-2 mb-0"
                         role="alert"
                         invisible="is_active">
                        <i class="fa fa-history fa-lg"/>
                        <span>This assignment has been <strong>returned</strong> and is now closed.</span>
                    </div> -->

                    <!-- ── Main fields ─────────────────────────────────── -->
                    <group>
                        <!-- Left: Assignment details -->
                        <group string="Assignment" name="assign_group">
                            <field name="asset_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="assign_date" readonly="1"/>
                            <field name="assigned_by" readonly="1"/>
                            <field name="condition_on_assign" readonly="1"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"
                                   readonly="1"/>
                        </group>

                        <!-- Right: Return details -->
                        <group string="Return" name="return_group">
                            <field name="return_date" readonly="1"/>
                            <field name="returned_by" readonly="1"/>
                            <field name="condition_on_return"
                                   readonly="1"
                                   invisible="not return_date"/>
                        </group>
                    </group>

                    <!-- ── Notes ──────────────────────────────────────── -->
                    <group string="Notes" name="notes_group">
                        <field name="notes"
                               nolabel="1"
                               colspan="2"
                               readonly="1"
                               placeholder="No notes recorded for this assignment."/>
                    </group>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         asset.assignment — List View
         ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_asset_assignment_list" model="ir.ui.view">
        <field name="name">asset.assignment.list</field>
        <field name="model">asset.assignment</field>
        <field name="arch" type="xml">
            <list string="Asset Assignments"
                  create="0"
                  delete="0"
                  edit="0"
                  decoration-success="is_active == True"
                  decoration-muted="is_active == False">

                <field name="asset_id" optional="show"/>
                <field name="employee_id" optional="show"/>
                <field name="assign_date" optional="show"/>
                <field name="condition_on_assign"
                       widget="badge"
                       decoration-success="condition_on_assign == 'new'"
                       decoration-info="condition_on_assign == 'good'"
                       decoration-warning="condition_on_assign == 'fair'"
                       decoration-danger="condition_on_assign == 'poor'"
                       optional="show"/>
                <field name="return_date" optional="show"/>
                <field name="condition_on_return"
                       widget="badge"
                       decoration-success="condition_on_return == 'good'"
                       decoration-warning="condition_on_return == 'fair'"
                       decoration-danger="condition_on_return in ('poor', 'damaged')"
                       optional="show"/>
                <field name="is_active"
                       widget="boolean_toggle"
                       readonly="1"
                       optional="show"/>
                <field name="assigned_by" optional="hide"/>
                <field name="returned_by" optional="hide"/>
                <field name="company_id"
                       groups="base.group_multi_company"
                       optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         asset.assignment — Search View
         ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_asset_assignment_search" model="ir.ui.view">
        <field name="name">asset.assignment.search</field>
        <field name="model">asset.assignment</field>
        <field name="arch" type="xml">
            <search string="Search Assignments">

                <!-- ── Full-text search fields ─────────────────────── -->
                <field name="asset_id"
                       string="Asset"
                       filter_domain="[('asset_id.name', 'ilike', self)]"/>
                <field name="employee_id" string="Employee"/>
                <field name="assigned_by" string="Assigned By"/>

                <!-- ── Quick-filters ───────────────────────────────── -->
                <separator/>

                <filter string="Active Assignments"
                        name="filter_active"
                        domain="[('is_active', '=', True)]"
                        help="Show only currently active (unreturned) assignments"/>

                <filter string="Returned"
                        name="filter_returned"
                        domain="[('is_active', '=', False), ('return_date', '!=', False)]"/>

                <filter string="Damaged on Return"
                        name="filter_damaged"
                        domain="[('condition_on_return', '=', 'damaged')]"/>

                <filter string="Assigned This Month"
                        name="filter_this_month"
                        domain="[('assign_date', '>=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>

                <!-- ── Group By ────────────────────────────────────── -->
                <separator/>

                
                <filter string="Employee"
                        name="group_employee"
                        context="{'group_by': 'employee_id'}"/>
                <filter string="Asset"
                        name="group_asset"
                        context="{'group_by': 'asset_id'}"/>
                <filter string="Assigned By"
                        name="group_assigned_by"
                        context="{'group_by': 'assigned_by'}"/>
                <filter string="Assignment Date"
                        name="group_assign_date"
                        context="{'group_by': 'assign_date:month'}"/>
                <filter string="Company"
                        name="group_company"
                        context="{'group_by': 'company_id'}"
                        />
                
               

            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         asset.assignment — Actions
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Main list action (default: show active only) -->
    <record id="action_asset_assignment" model="ir.actions.act_window">
        <field name="name">Asset Assignments</field>
        <field name="res_model">asset.assignment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No assignments yet
            </p>
            <p>
                Use the <strong>Assign</strong> button on an available asset
                to assign it to an employee.
            </p>
        </field>
    </record>

    <!-- Active-only action (used from dashboard "Assigned" KPI card) -->
    <record id="action_asset_assignment_active" model="ir.actions.act_window">
        <field name="name">Active Assignments</field>
        <field name="res_model">asset.assignment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_active', '=', True)]</field>
        <field name="context">{'search_default_filter_active': 1}</field>
    </record>

</odoo>