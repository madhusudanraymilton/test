<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_product_template_form_inherit_asset" model="ir.ui.view">
        <field name="name">product.template.form.asset</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <!-- Insert inside General Information tab -->
            <xpath expr="//div[@name='options']" position="inside">

                <field name="is_asset"/>
                <label for="is_asset"/>

                <!-- <field name="asset_category_id"/> -->

            </xpath>
            <xpath expr="//div[@name='options']" position="before">
                <field name="asset_category_id" string="Asset Category" placeholder="Select Asset Category" invisible="not is_asset"/>
            </xpath>

        </field>
    </record>
</odoo>