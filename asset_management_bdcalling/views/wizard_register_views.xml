<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_asset_register_wizard_form" model="ir.ui.view">
        <field name="name">asset.register.wizard.form</field>
        <field name="model">asset.register.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Asset">
                <sheet>

                    <!-- MUST be present (invisible) so context default_asset_id
                         is picked up by the ORM. -->
                    <field name="asset_id" invisible="1"/>

                    <!-- category_domain_ids is computed with sudo() — drives
                         the domain on category_id to bypass multi-company rule -->
                    <field name="category_domain_ids" invisible="1"/>

                    <!-- ── Serial Number ──────────────────────────────────── -->
                    <group string="Serial Number">
                        <field name="registered_lot_ids" invisible="1"/>
                        <field name="lot_id"
                               options="{'no_create': True}"
                               domain="[('id', 'not in', registered_lot_ids)]"
                               readonly="asset_id != False"/>
                        <field name="product_id" readonly="1"/>
                    </group>

                    <!-- ── Purchase Information (auto-filled from PO) ──────── -->
                    <group string="Purchase Information">
                        <field name="currency_id" invisible="1"/>
                        <field name="purchase_price"/>
                        <field name="purchase_date"/>
                        <field name="purchase_order_id"
                               readonly="1"
                               invisible="not purchase_order_id"
                               options="{'no_open': False}"
                               string="Purchase Order"/>
                        <field name="purchase_order_line_id"
                               readonly="1"
                               invisible="not purchase_order_line_id"
                               string="PO Line"/>

                        <!-- Shown only when no PO was found for this lot -->
                        <div class="alert alert-info"
                             role="alert"
                             colspan="2"
                             invisible="purchase_order_id">
                            <i class="fa fa-info-circle me-1"/>
                            No purchase order found for this serial number.
                            Please enter <strong>Purchase Price</strong>
                            and <strong>Purchase Date</strong> manually.
                        </div>
                    </group>

                    <!-- ── Classification ─────────────────────────────────── -->
                    <group string="Classification">
                        <!--
                            Domain uses category_domain_ids (pre-loaded via
                            sudo in _compute_category_domain_ids) so the
                            multi-company rule on account.asset does not block
                            the user from seeing categories of other companies.
                        -->
                        <field name="category_id"
                               domain="[('id', 'in', category_domain_ids)]"
                               options="{'no_create': True}"/>
                        <field name="source_location_id"/>
                    </group>

                    <!-- ── Notes ──────────────────────────────────────────── -->
                    <group string="Notes">
                        <field name="notes"
                               nolabel="1"
                               colspan="2"
                               placeholder="Optional notes about this registration…"/>
                    </group>

                </sheet>
                <footer>
                    <button name="action_register"
                            type="object"
                            string="Register Asset"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Standalone action (from menu or button_box) -->
    <record id="action_asset_register_wizard" model="ir.actions.act_window">
        <field name="name">Register Asset</field>
        <field name="res_model">asset.register.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>