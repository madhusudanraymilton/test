<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_asset_assign_wizard_form" model="ir.ui.view">
        <field name="name">asset.assign.wizard.form</field>
        <field name="model">asset.assign.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign Asset to Employee">
                <sheet>
                    <group>
                        <field name="asset_id" readonly="1"/>
                        <field name="employee_id"/>
                        <field name="assign_date"/>
                        <field name="condition_on_assign"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" colspan="2"
                               placeholder="Optional notes about this assignment..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_assign" type="object"
                            string="Assign Asset" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
