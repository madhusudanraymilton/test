<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_asset_unregister_wizard_form" model="ir.ui.view">
        <field name="name">asset.unregister.wizard.form</field>
        <field name="model">asset.unregister.wizard</field>
        <field name="arch" type="xml">
            <form string="Unregister Asset">
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        <strong>Warning:</strong>
                        Unregistering will move the serial number back to inventory
                        and delete all unposted depreciation lines.
                    </div>
                    <group>
                        <field name="asset_id" readonly="1"/>
                        <field name="destination_location_id"/>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1" colspan="2"
                               placeholder="Provide a reason for unregistering this asset..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_unregister" type="object"
                            string="Confirm Unregistration" class="btn-warning"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
