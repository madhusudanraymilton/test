<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="asset_management_bdcalling.AssetDashboard">
        <div class="o_asset_dashboard">

            <!-- Control Panel -->
            <div class="o_asset_dashboard_header d-flex align-items-center justify-content-between px-3 py-2 border-bottom bg-white">
                <h4 class="mb-0 fw-bold">Asset Dashboard</h4>
                <button class="btn btn-sm btn-outline-secondary" t-on-click="refresh">
                    <i class="fa fa-refresh me-1"/>Refresh
                </button>
            </div>

            <!-- Loading -->
            <t t-if="state.loading">
                <div class="d-flex flex-column align-items-center justify-content-center" style="min-height:300px;">
                    <i class="fa fa-spinner fa-spin fa-3x text-muted"/>
                    <p class="text-muted mt-3">Loading dashboard...</p>
                </div>
            </t>

            <!-- Content -->
            <t t-else="">
                <div class="o_asset_dashboard_content p-4">

                    <!-- Row 1: Count KPIs -->
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card ams-kpi-card border-start border-primary border-4 h-100"
                                 style="cursor:pointer;" t-on-click="openAllAssets">
                                <div class="card-body d-flex align-items-center gap-3">
                                    <div class="ams-kpi-icon bg-primary bg-opacity-10 rounded-3 p-3">
                                        <i class="fa fa-cubes fa-xl text-primary"/>
                                    </div>
                                    <div>
                                        <div class="fs-2 fw-bold text-primary lh-1">
                                            <t t-esc="state.total"/>
                                        </div>
                                        <div class="text-muted small mt-1">Total Assets</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card ams-kpi-card border-start border-success border-4 h-100"
                                 style="cursor:pointer;" t-on-click="openAvailableAssets">
                                <div class="card-body d-flex align-items-center gap-3">
                                    <div class="ams-kpi-icon bg-success bg-opacity-10 rounded-3 p-3">
                                        <i class="fa fa-check-circle fa-xl text-success"/>
                                    </div>
                                    <div>
                                        <div class="fs-2 fw-bold text-success lh-1">
                                            <t t-esc="state.available"/>
                                        </div>
                                        <div class="text-muted small mt-1">Available</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card ams-kpi-card border-start border-info border-4 h-100"
                                 style="cursor:pointer;" t-on-click="openAssignedAssets">
                                <div class="card-body d-flex align-items-center gap-3">
                                    <div class="ams-kpi-icon bg-info bg-opacity-10 rounded-3 p-3">
                                        <i class="fa fa-user fa-xl text-info"/>
                                    </div>
                                    <div>
                                        <div class="fs-2 fw-bold text-info lh-1">
                                            <t t-esc="state.assigned"/>
                                        </div>
                                        <div class="text-muted small mt-1">Assigned</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card ams-kpi-card border-start border-danger border-4 h-100">
                                <div class="card-body d-flex align-items-center gap-3">
                                    <div class="ams-kpi-icon bg-danger bg-opacity-10 rounded-3 p-3">
                                        <i class="fa fa-trash fa-xl text-danger"/>
                                    </div>
                                    <div>
                                        <div class="fs-2 fw-bold text-danger lh-1">
                                            <t t-esc="state.scrapped_disposed"/>
                                        </div>
                                        <div class="text-muted small mt-1">Scrapped / Disposed</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2: Financial KPIs -->
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-md-4">
                            <div class="card ams-kpi-card border-start border-secondary border-4 h-100">
                                <div class="card-body d-flex align-items-center gap-3">
                                    <div class="ams-kpi-icon bg-secondary bg-opacity-10 rounded-3 p-3">
                                        <i class="fa fa-money fa-xl text-secondary"/>
                                    </div>
                                    <div>
                                        <div class="fs-4 fw-bold text-secondary lh-1">
                                            <t t-esc="formatCurrency(state.total_value)"/>
                                        </div>
                                        <div class="text-muted small mt-1">Total Purchase Value</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="card ams-kpi-card border-start border-warning border-4 h-100">
                                <div class="card-body d-flex align-items-center gap-3">
                                    <div class="ams-kpi-icon bg-warning bg-opacity-10 rounded-3 p-3">
                                        <i class="fa fa-line-chart fa-xl text-warning"/>
                                    </div>
                                    <div>
                                        <div class="fs-4 fw-bold text-warning lh-1">
                                            <t t-esc="formatCurrency(state.net_book_value)"/>
                                        </div>
                                        <div class="text-muted small mt-1">Net Book Value</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="card ams-kpi-card border-start border-dark border-4 h-100"
                                 style="cursor:pointer;" t-on-click="openPendingDepreciation">
                                <div class="card-body d-flex align-items-center gap-3">
                                    <div class="ams-kpi-icon bg-dark bg-opacity-10 rounded-3 p-3">
                                        <i class="fa fa-clock-o fa-xl text-dark"/>
                                    </div>
                                    <div>
                                        <div class="fs-4 fw-bold text-dark lh-1">
                                            <t t-esc="state.pending_depreciation"/>
                                        </div>
                                        <div class="text-muted small mt-1">Pending Depreciation Lines</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Row 3: Category Chart + Status Breakdown -->
                    <div class="row g-3">
                        <div class="col-12 col-lg-7">
                            <div class="card h-100">
                                <div class="card-header bg-white">
                                    <h6 class="mb-0 fw-bold">
                                        <i class="fa fa-bar-chart me-2 text-muted"/>Assets by Category
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <t t-if="state.by_category.length === 0">
                                        <div class="text-center text-muted py-4">
                                            <i class="fa fa-inbox fa-2x mb-2"/>
                                            <p class="mb-0">No asset data available.</p>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <t t-foreach="state.by_category" t-as="cat">
                                            <div class="mb-3">
                                                <div class="d-flex justify-content-between mb-1">
                                                    <span class="small fw-semibold">
                                                        <t t-esc="cat.category"/>
                                                    </span>
                                                    <span class="small text-muted">
                                                        <t t-esc="cat.count"/> assets
                                                    </span>
                                                </div>
                                                <div class="progress" style="height:16px;">
                                                    <div class="progress-bar bg-primary"
                                                         t-attf-style="width: {{ getPct(cat.count) }}%"
                                                         t-attf-aria-valuenow="{{ getPct(cat.count) }}"
                                                         aria-valuemin="0"
                                                         aria-valuemax="100">
                                                        <t t-esc="getPct(cat.count)"/>%
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </t>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-5">
                            <div class="card h-100">
                                <div class="card-header bg-white">
                                    <h6 class="mb-0 fw-bold">
                                        <i class="fa fa-pie-chart me-2 text-muted"/>Status Breakdown
                                    </h6>
                                </div>
                                <div class="card-body p-0">
                                    <table class="table table-sm mb-0">
                                        <tbody>
                                            <tr>
                                                <td class="ps-3">
                                                    <span class="badge bg-success">Available</span>
                                                </td>
                                                <td class="text-end pe-3 fw-bold">
                                                    <t t-esc="state.available"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="ps-3">
                                                    <span class="badge bg-info">Assigned</span>
                                                </td>
                                                <td class="text-end pe-3 fw-bold">
                                                    <t t-esc="state.assigned"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="ps-3">
                                                    <span class="badge bg-warning text-dark">Draft</span>
                                                </td>
                                                <td class="text-end pe-3 fw-bold">
                                                    <t t-esc="state.total - state.available - state.assigned - state.scrapped_disposed"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="ps-3">
                                                    <span class="badge bg-danger">Scrapped / Disposed</span>
                                                </td>
                                                <td class="text-end pe-3 fw-bold">
                                                    <t t-esc="state.scrapped_disposed"/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </t>
        </div>
    </t>

</templates>
