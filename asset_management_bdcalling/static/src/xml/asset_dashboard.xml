<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="asset_management_bdcalling.AssetDashboard">
        <div class="o_asset_dashboard">

            <!-- HEADER -->
            <div class="o_asset_dashboard_header d-flex justify-content-between align-items-center">
                <h3 class="fw-bold">Asset Management Dashboard</h3>

                <button class="btn btn-primary btn-sm" t-on-click="refresh">
                    <i class="fa fa-refresh me-2"/>Refresh
                </button>
            </div>

            <!-- LOADING STATE -->
            <t t-if="state.loading">
                <div class="ams-loading">
                    <i class="fa fa-spinner fa-spin fa-3x"/>
                    <p>Loading dashboard...</p>
                </div>
            </t>

            <!-- DASHBOARD CONTENT -->
            <t t-else="">
                <div class="o_asset_dashboard_content">

                    <!-- KPI ROW -->
                    <div class="row g-4">

                        <!-- TOTAL ASSETS -->
                        <div class="col-xl-3 col-md-6">
                            <div class="card ams-kpi-card" t-on-click="openAllAssets">
                                <div class="card-body">
                                    <div class="ams-kpi-icon bg-primary">
                                        <i class="fa fa-cubes"/>
                                    </div>

                                    <div class="ams-kpi-data">
                                        <div class="ams-kpi-number">
                                            <t t-esc="state.total"/>
                                        </div>
                                        <div class="ams-kpi-label">
                                            Total Assets
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- AVAILABLE -->
                        <div class="col-xl-3 col-md-6">
                            <div class="card ams-kpi-card" t-on-click="openAvailableAssets">
                                <div class="card-body">
                                    <div class="ams-kpi-icon bg-success">
                                        <i class="fa fa-check"/>
                                    </div>

                                    <div class="ams-kpi-data">
                                        <div class="ams-kpi-number">
                                            <t t-esc="state.available"/>
                                        </div>
                                        <div class="ams-kpi-label">
                                            Available Assets
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ASSIGNED -->
                        <div class="col-xl-3 col-md-6">
                            <div class="card ams-kpi-card" t-on-click="openAssignedAssets">
                                <div class="card-body">
                                    <div class="ams-kpi-icon bg-info">
                                        <i class="fa fa-user"/>
                                    </div>

                                    <div class="ams-kpi-data">
                                        <div class="ams-kpi-number">
                                            <t t-esc="state.assigned"/>
                                        </div>
                                        <div class="ams-kpi-label">
                                            Assigned Assets
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SCRAPPED -->
                        <div class="col-xl-3 col-md-6">
                            <div class="card ams-kpi-card">
                                <div class="card-body">
                                    <div class="ams-kpi-icon bg-danger">
                                        <i class="fa fa-trash"/>
                                    </div>

                                    <div class="ams-kpi-data">
                                        <div class="ams-kpi-number">
                                            <t t-esc="state.scrapped_disposed"/>
                                        </div>
                                        <div class="ams-kpi-label">
                                            Scrapped
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- SECOND ROW -->
                    <div class="row g-4 mt-1">

                        <!-- CATEGORY CHART -->
                        <div class="col-lg-8">
                            <div class="card">
                                <div class="card-header">
                                    <h6 class="fw-bold">Assets by Category</h6>
                                </div>

                                <div class="card-body">
                                    <canvas id="categoryChart"/>
                                </div>
                            </div>
                        </div>

                        <!-- STATUS BREAKDOWN -->
                        <div class="col-lg-4">
                            <div class="card">
                                <div class="card-header">
                                    <h6 class="fw-bold">Status Breakdown</h6>
                                </div>

                                <div class="card-body">
                                    <ul class="ams-status-list">
                                        <li>
                                            <span class="badge bg-success">Available</span>
                                            <span t-esc="state.available"/>
                                        </li>

                                        <li>
                                            <span class="badge bg-info">Assigned</span>
                                            <span t-esc="state.assigned"/>
                                        </li>

                                        <li>
                                            <span class="badge bg-danger">Scrapped</span>
                                            <span t-esc="state.scrapped_disposed"/>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- RECENT ASSIGNMENTS -->
                    <div class="card mt-4">
                        <div class="card-header">
                            <h6 class="fw-bold">Recent Assignments</h6>
                        </div>

                        <div class="card-body">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Asset</th>
                                        <th>Employee</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <t t-foreach="state.recent_assignments" t-as="rec" t-key="rec.id">
                                        <tr>
                                            <td><t t-esc="rec.asset"/></td>
                                            <td><t t-esc="rec.employee"/></td>
                                            <td><t t-esc="rec.date"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </t>

        </div>
    </t>

</templates>