<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="asset_management_bdcalling.AssetDashboard">
<div class="ams-dashboard">

    <!-- ══ HEADER ════════════════════════════════════════════════════════════ -->
    <div class="ams-header">
        <div class="ams-header-left">
            <div class="ams-header-icon">
                <i class="fa fa-cubes"/>
            </div>
            <div>
                <h1 class="ams-title">Asset Management</h1>
                <p class="ams-subtitle">Real-time overview of your organization's assets</p>
            </div>
        </div>
        <button class="ams-refresh-btn" t-on-click="refresh">
            <i class="fa fa-refresh"/>
            <span>Refresh</span>
        </button>
    </div>

    <!-- ══ LOADING STATE ═════════════════════════════════════════════════════ -->
    <t t-if="state.loading">
        <div class="ams-loading">
            <div class="ams-spinner"></div>
            <p class="ams-loading-text">Loading dashboard data…</p>
        </div>
    </t>

    <!-- ══ DASHBOARD CONTENT ═════════════════════════════════════════════════ -->
    <t t-else="">

        <!-- KPI GRID -->
        <div class="ams-kpi-grid">

            <!-- Total Assets -->
            <div class="ams-kpi-card ams-kpi-blue" t-on-click="openAllAssets">
                <div class="ams-kpi-icon-wrap">
                    <i class="fa fa-cubes"/>
                </div>
                <div class="ams-kpi-body">
                    <span class="ams-kpi-value" t-esc="state.total"/>
                    <span class="ams-kpi-label">Total Assets</span>
                </div>
                <div class="ams-kpi-arrow"><i class="fa fa-arrow-right"/></div>
            </div>

            <!-- Available -->
            <div class="ams-kpi-card ams-kpi-green" t-on-click="openAvailableAssets">
                <div class="ams-kpi-icon-wrap">
                    <i class="fa fa-check-circle"/>
                </div>
                <div class="ams-kpi-body">
                    <span class="ams-kpi-value" t-esc="state.available"/>
                    <span class="ams-kpi-label">Available</span>
                </div>
                <div class="ams-kpi-arrow"><i class="fa fa-arrow-right"/></div>
            </div>

            <!-- Assigned -->
            <div class="ams-kpi-card ams-kpi-indigo" t-on-click="openAssignedAssets">
                <div class="ams-kpi-icon-wrap">
                    <i class="fa fa-user-circle"/>
                </div>
                <div class="ams-kpi-body">
                    <span class="ams-kpi-value" t-esc="state.assigned"/>
                    <span class="ams-kpi-label">Assigned</span>
                </div>
                <div class="ams-kpi-arrow"><i class="fa fa-arrow-right"/></div>
            </div>

            <!-- Scrapped / Disposed -->
            <div class="ams-kpi-card ams-kpi-rose" t-on-click="openScrappedAssets">
                <div class="ams-kpi-icon-wrap">
                    <i class="fa fa-ban"/>
                </div>
                <div class="ams-kpi-body">
                    <span class="ams-kpi-value" t-esc="state.scrapped_disposed"/>
                    <span class="ams-kpi-label">Scrapped / Disposed</span>
                </div>
                <div class="ams-kpi-arrow"><i class="fa fa-arrow-right"/></div>
            </div>

        </div>

        <!-- FINANCIAL STRIP -->
        <div class="ams-finance-strip">
            <div class="ams-finance-item">
                <span class="ams-finance-label">
                    <i class="fa fa-tag me-1"/> Total Purchase Value
                </span>
                <span class="ams-finance-value">
                    <t t-esc="formatCurrency(state.total_value)"/>
                </span>
            </div>
            <div class="ams-finance-divider"/>
            <div class="ams-finance-item">
                <span class="ams-finance-label">
                    <i class="fa fa-balance-scale me-1"/> Net Book Value
                </span>
                <span class="ams-finance-value ams-finance-value-accent">
                    <t t-esc="formatCurrency(state.net_book_value)"/>
                </span>
            </div>
            <div class="ams-finance-divider"/>
            <div class="ams-finance-item ams-finance-clickable" t-on-click="openPendingDepreciation">
                <span class="ams-finance-label">
                    <i class="fa fa-clock-o me-1"/> Pending Depreciation Lines
                </span>
                <span class="ams-finance-value ams-finance-value-warn">
                    <t t-esc="state.pending_depreciation"/>
                </span>
            </div>
        </div>

        <!-- CHARTS + STATUS ROW -->
        <div class="ams-charts-row">

            <!-- Category Bar Chart -->
            <div class="ams-card ams-card-chart">
                <div class="ams-card-header">
                    <span class="ams-card-title">
                        <i class="fa fa-bar-chart me-2"/>Assets by Category
                    </span>
                    <span class="ams-card-badge">
                        <t t-esc="state.by_category.length"/> categories
                    </span>
                </div>
                <div class="ams-chart-wrap">
                    <canvas t-ref="categoryChart" class="ams-canvas"/>
                </div>
            </div>

            <!-- Status Breakdown -->
            <div class="ams-card ams-card-status">
                <div class="ams-card-header">
                    <span class="ams-card-title">
                        <i class="fa fa-pie-chart me-2"/>Status Breakdown
                    </span>
                </div>
                <div class="ams-status-list">

                    <div class="ams-status-item" t-on-click="openAvailableAssets">
                        <div class="ams-status-left">
                            <span class="ams-status-dot ams-dot-green"/>
                            <span class="ams-status-name">Available</span>
                        </div>
                        <div class="ams-status-right">
                            <span class="ams-status-count"><t t-esc="state.available"/></span>
                            <div class="ams-status-bar-wrap">
                                <div class="ams-status-bar ams-bar-green"
                                     t-attf-style="width: #{state.total ? Math.round(state.available / state.total * 100) : 0}%"/>
                            </div>
                        </div>
                    </div>

                    <div class="ams-status-item" t-on-click="openAssignedAssets">
                        <div class="ams-status-left">
                            <span class="ams-status-dot ams-dot-indigo"/>
                            <span class="ams-status-name">Assigned</span>
                        </div>
                        <div class="ams-status-right">
                            <span class="ams-status-count"><t t-esc="state.assigned"/></span>
                            <div class="ams-status-bar-wrap">
                                <div class="ams-status-bar ams-bar-indigo"
                                     t-attf-style="width: #{state.total ? Math.round(state.assigned / state.total * 100) : 0}%"/>
                            </div>
                        </div>
                    </div>

                    <div class="ams-status-item" t-on-click="openScrappedAssets">
                        <div class="ams-status-left">
                            <span class="ams-status-dot ams-dot-rose"/>
                            <span class="ams-status-name">Scrapped / Disposed</span>
                        </div>
                        <div class="ams-status-right">
                            <span class="ams-status-count"><t t-esc="state.scrapped_disposed"/></span>
                            <div class="ams-status-bar-wrap">
                                <div class="ams-status-bar ams-bar-rose"
                                     t-attf-style="width: #{state.total ? Math.round(state.scrapped_disposed / state.total * 100) : 0}%"/>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Utilisation ring (pure CSS) -->
                <div class="ams-util-section">
                    <p class="ams-util-label">Utilisation Rate</p>
                    <div class="ams-util-ring-wrap">
                        <div class="ams-util-ring">
                            <span class="ams-util-pct">
                                <t t-esc="state.total ? Math.round(state.assigned / state.total * 100) : 0"/>%
                            </span>
                        </div>
                        <p class="ams-util-sub">of active assets currently assigned</p>
                    </div>
                </div>
            </div>

        </div>

        <!-- RECENT ASSIGNMENTS TABLE -->
        <div class="ams-card ams-card-table">
            <div class="ams-card-header">
                <span class="ams-card-title">
                    <i class="fa fa-history me-2"/>Recent Assignments
                </span>
                <button class="ams-view-all-btn" t-on-click="openAssignedAssets">
                    View all <i class="fa fa-arrow-right ms-1"/>
                </button>
            </div>
            <div class="ams-table-wrap">
                <t t-if="state.recent_assignments.length">
                    <table class="ams-table">
                        <thead>
                            <tr>
                                <th>Asset Code</th>
                                <th>Asset Name</th>
                                <th>Employee</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.recent_assignments" t-as="rec" t-key="rec.id">
                                <tr>
                                    <td>
                                        <span class="ams-code-badge">
                                            <t t-esc="rec.asset_code or '-'"/>
                                        </span>
                                    </td>
                                    <td class="ams-asset-name"><t t-esc="rec.asset"/></td>
                                    <td>
                                        <div class="ams-employee-cell">
                                            <div class="ams-avatar">
                                                <t t-esc="rec.employee ? rec.employee[0].toUpperCase() : '?'"/>
                                            </div>
                                            <t t-esc="rec.employee"/>
                                        </div>
                                    </td>
                                    <td class="ams-date"><t t-esc="rec.date"/></td>
                                    <td>
                                        <t t-if="rec.is_active">
                                            <span class="ams-badge ams-badge-active">Active</span>
                                        </t>
                                        <t t-else="">
                                            <span class="ams-badge ams-badge-returned">Returned</span>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-else="">
                    <div class="ams-empty-state">
                        <i class="fa fa-inbox ams-empty-icon"/>
                        <p>No assignments found</p>
                    </div>
                </t>
            </div>
        </div>

    </t><!-- end t-else -->

</div>
</t>

</templates>