<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =========================
         LIST VIEW (Odoo 19)
    ========================== -->
    <record id="view_res_district_list" model="ir.ui.view">
        <field name="name">res.district.list</field>
        <field name="model">res.district</field>
        <field name="arch" type="xml">
            <list string="Districts">
                <field name="name"/>
                <field name="state_id"/>
                <field name="country_id"/>
            </list>
        </field>
    </record>


    <!-- =========================
         FORM VIEW
    ========================== -->
    <record id="view_res_district_form" model="ir.ui.view">
        <field name="name">res.district.form</field>
        <field name="model">res.district</field>
        <field name="arch" type="xml">
            <form string="District">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="state_id"/>
                        <field name="country_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <!-- =========================
         SEARCH VIEW
    ========================== -->
