            </search>
        </field>
    </record> -->


    <!-- =========================
         ACTION
    ========================== -->
    <record id="action_res_district" model="ir.actions.act_window">
        <field name="name">Districts</field>
        <field name="res_model">res.district</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="search_view_id" ref="view_res_district_search"/> -->
    </record>

    <menuitem 
        id="menu_res_partner_district"
        name="District"
        parent="contacts.menu_localisation"
        action="action_res_district"
        sequence="20"
    />

</odoo>