    <!-- =========================
         ACTION
    ========================== -->
    <record id="action_res_thana" model="ir.actions.act_window">
        <field name="name">Thanas</field>
        <field name="res_model">res.thana</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="search_view_id" ref="view_res_thana_search"/> -->
    </record>

