<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =========================
         LIST VIEW (Odoo 19)
    ========================== -->
    <record id="view_res_thana_list" model="ir.ui.view">
        <field name="name">res.thana.list</field>
        <field name="model">res.thana</field>
        <field name="arch" type="xml">
            <list string="Thanas">
                <field name="name"/>
                <field name="district_id"/>
                <field name="state_id"/>
                <field name="country_id"/>
            </list>
        </field>
    </record>


    <!-- =========================
         FORM VIEW
    ========================== -->
    <record id="view_res_thana_form" model="ir.ui.view">
        <field name="name">res.thana.form</field>
        <field name="model">res.thana</field>
        <field name="arch" type="xml">
            <form string="Thana">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="district_id"/>
                        <field name="state_id"/>
                        <field name="country_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


