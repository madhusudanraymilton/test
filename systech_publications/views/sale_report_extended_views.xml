<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sale_order_search_inherit_geography" model="ir.ui.view">
            <field name="name">sale.order.search.inherit.geography</field>
            <field name="model">sale.report</field>
            <field name="inherit_id" ref="sale.view_order_product_search"/>
            <field name="arch" type="xml">

                <!-- 1. Add searchable fields before the existing filters -->
                <xpath expr="//search/field[last()]" position="after">
                    <field name="thana_id"/>
                    <field name="district_id"/>
                    <field name="state_id"/>
                    <field name="country_id"/>
                </xpath>

                <!-- 2. Append group-by filters into the existing Group By group -->
                <xpath expr="//filter[@name='Customer']" position="after">
                    <separator string="Geographical Grouping"/>
                    <filter string="Thana" name="group_by_thana"    context="{'group_by': 'thana_id'}"/>
                    <filter string="District" name="group_by_district" context="{'group_by': 'district_id'}"/>
                    <filter string="Division" name="group_by_state" context="{'group_by': 'state_id'}"/>
                    <filter string="Country" name="group_by_country" context="{'group_by': 'country_id'}"/>
                    <separator string="Geographical Grouping"/>
                </xpath>


            </field>
        </record>
</odoo>