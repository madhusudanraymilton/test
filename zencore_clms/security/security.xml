<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         SECURITY GROUPS
         SRS §10 — Separation of Duties
         Each role has a strictly defined set of permitted operations.
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="module_category_zencore_clm" model="ir.module.category">
        <field name="name">Zencore CLM</field>
        <field name="description">Zencore CLM Security Roles</field>
        <field name="sequence">25</field>
    </record>

    <record id="module_zencore_clm" model="res.groups.privilege">
        <field name="name">Zencore CLM</field>
        <field name="category_id" ref="module_category_zencore_clm"/>
    </record>

    <!-- Salesperson: create quotations, record customer acceptance -->
    <record id="group_zencore_clm_salesperson" model="res.groups">
        <field name="name">Zencore CLM Salesperson</field>
        <field name="privilege_id" ref="module_zencore_clm"/>
    </record>

    <!-- Sales Manager: confirm SOs, view all orders in company -->
    <record id="group_zencore_clm_sales_manager" model="res.groups">
        <field name="name">Zencore CLM Sales Manager</field>
        <field name="privilege_id" ref="module_zencore_clm"/>
    </record>

    <!-- CCM (Credit & Collections Manager): set limits via workflow, record acceptances -->
    <record id="group_zencore_clm_ccm" model="res.groups">
        <field name="name">Zencore CLM CCM</field>
        <field name="privilege_id" ref="module_zencore_clm"/>
    </record>

    <!-- Warehouse: validate deliveries only -->
    <record id="group_zencore_clm_warehouse" model="res.groups">
        <field name="name">Zencore CLM Warehouse</field>
        <field name="privilege_id" ref="module_zencore_clm"/>
    </record>

    <!-- TDO (Territory/Technical Delivery Officer): create and post invoices only -->
    <record id="group_zencore_clm_tdo" model="res.groups">
        <field name="name">Zencore CLM TDO</field>
        <field name="privilege_id" ref="module_zencore_clm"/>
    </record>

    <!-- Finance: approve/reject limit requests, register payments, reconcile -->
    <record id="group_zencore_clm_finance" model="res.groups">
        <field name="name">Zencore CLM Finance</field>
        <field name="privilege_id" ref="module_zencore_clm"/>
    </record>


    <!-- ══════════════════════════════════════════════════════════════════════
         RECORD RULES — Row-level security
         NOTE: Record rules FILTER rows for users who already have model-level
         access (ir.model.access.csv). They do NOT grant access by themselves.
    ══════════════════════════════════════════════════════════════════════ -->

    <!-- ── SALE ORDER RULES ─────────────────────────────────────────────── -->

    <!-- Salesperson: sees only their own quotations/orders -->
    <record id="rule_so_salesperson_own" model="ir.rule">
        <field name="name">SO: Salesperson sees own orders only</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_zencore_clm_salesperson'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Sales Manager: sees all orders in their company (no create — SoD) -->
    <record id="rule_so_sales_manager_company" model="ir.rule">
        <field name="name">SO: Sales Manager sees company orders</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="domain_force">[('company_id', '=', user.company_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_zencore_clm_sales_manager'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- CCM: read-only on all company SOs (for acceptance actions) -->
    <record id="rule_so_ccm_company" model="ir.rule">
        <field name="name">SO: CCM read-write on company orders</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="domain_force">[('company_id', '=', user.company_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_zencore_clm_ccm'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Finance: read-only on all company SOs (visibility for payment context) -->
    <record id="rule_so_finance_company" model="ir.rule">
        <field name="name">SO: Finance reads company orders</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="domain_force">[('company_id', '=', user.company_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_zencore_clm_finance'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ── STOCK PICKING RULES ───────────────────────────────────────────── -->

    <!-- Warehouse: only outgoing pickings in their company -->
    <record id="rule_picking_warehouse_outgoing" model="ir.rule">
        <field name="name">Picking: Warehouse sees outgoing transfers only</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="domain_force">
            [('picking_type_code', '=', 'outgoing'),
             ('company_id', '=', user.company_id.id)]
        </field>
        <field name="groups" eval="[(4, ref('group_zencore_clm_warehouse'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ── ACCOUNT MOVE RULES ────────────────────────────────────────────── -->

    <!-- TDO: only customer invoices (out_invoice) in their company -->
    <record id="rule_invoice_tdo_out_invoice" model="ir.rule">
        <field name="name">Invoice: TDO sees customer invoices only</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="domain_force">
            [('move_type', '=', 'out_invoice'),
             ('company_id', '=', user.company_id.id)]
        </field>
        <field name="groups" eval="[(4, ref('group_zencore_clm_tdo'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Finance: all moves in company (payment + reconciliation) -->
    <record id="rule_invoice_finance_company" model="ir.rule">
        <field name="name">Invoice: Finance sees all company moves</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="domain_force">[('company_id', '=', user.company_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_zencore_clm_finance'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ── CLM LIMIT CHANGE REQUEST RULES ───────────────────────────────── -->

    <!-- CCM: sees only their own requests (initiated_by = current user) -->
    <record id="rule_clm_request_ccm_own" model="ir.rule">
        <field name="name">CLM Request: CCM sees own requests only</field>
        <field name="model_id" ref="zencore_clms.model_clm_limit_change_request"/>
        <field name="domain_force">[('initiated_by', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_zencore_clm_ccm'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Finance: sees ALL requests for review and approval -->
    <record id="rule_clm_request_finance_all" model="ir.rule">
        <field name="name">CLM Request: Finance sees all requests</field>
        <field name="model_id" ref="zencore_clms.model_clm_limit_change_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_zencore_clm_finance'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Sales Manager: read-only on all requests (visibility only) -->
    <record id="rule_clm_request_sales_manager_readonly" model="ir.rule">
        <field name="name">CLM Request: Sales Manager read-only on all</field>
        <field name="model_id" ref="zencore_clms.model_clm_limit_change_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_zencore_clm_sales_manager'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
