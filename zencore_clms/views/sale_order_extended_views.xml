<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        sale.order — CLM Extension Views (v2.0)

        Changes from v1.x:
        ──────────────────
        - Removed Customer Acceptance and Bank Acceptance BUTTONS from SO header.
          Per SRS §4.1/§4.2: acceptance fields are on Customer Invoice (account.move),
          not on the sale order. The invoice-level acceptance buttons are in
          account_move_extended_views.xml.

        - CLM Credit Control tab now shows INFORMATIONAL ALERTS about invoice
          acceptance states (read-only summary, drives user to open the invoice).

        - clm_show_customer_acceptance_btn / clm_show_bank_acceptance_btn are now
          purely informational (do linked invoices need acceptance?) — not action triggers.

        - clm_state statusbar retained (operational stage, SRS §2.2).
    -->

    <record id="view_order_form_clm_statusbar" model="ir.ui.view">
        <field name="name">sale.order.form.clm.statusbar</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- ── 1. Replace default Odoo status bar with CLM operational stage bar ── -->
            <xpath expr="//header/field[@name='state'][@widget='statusbar']" position="replace">
                <field name="state" invisible="1"/>
                <field
                    name="clm_state"
                    widget="statusbar"
                    statusbar_visible="pi,partially_delivered,fully_delivered,partially_invoiced,fully_invoiced,partially_paid,fully_paid"
                />
            </xpath>

            <!-- ── 2. CLM Credit Control tab ── -->
            <xpath expr="//page[@name='order_lines']" position="after">
                <page string="Credit Control" name="clm_info">

                    <!-- Hidden visibility fields -->
                    <field name="clm_show_customer_acceptance_btn" invisible="1"/>
                    <field name="clm_show_bank_acceptance_btn"     invisible="1"/>
                    <field name="clm_show_payment_action"          invisible="1"/>

                    <!-- ════════════════════════════════════════════════════
                         A — ACCEPTANCE STATUS ALERTS
                         These are INFORMATIONAL only. Actual acceptance
                         buttons are on the linked Invoice(s).
                    ════════════════════════════════════════════════════ -->

                    <!--
                        Invoices pending customer acceptance.
                        Guide user to open the invoice.
                    -->
                    <div class="alert alert-warning" role="alert"
                         invisible="not clm_show_customer_acceptance_btn">
                        <strong>⏳ Customer Acceptance Pending</strong><br/>
                        One or more linked invoices are awaiting Customer Acceptance.<br/>
                        Open the related invoice(s) and click the
                        <strong>✔ Customer Acceptance</strong> button.
                    </div>

                    <!--
                        Customer accepted; awaiting bank acceptance.
                    -->
                    <div class="alert alert-info" role="alert"
                         invisible="not clm_show_bank_acceptance_btn">
                        <strong>⏳ Bank Acceptance Pending</strong><br/>
                        Customer Acceptance is confirmed on one or more invoices,
                        but Bank Acceptance is still outstanding.<br/>
                        Open the related invoice(s) and click the
                        <strong>🏦 Bank Acceptance</strong> button.
                    </div>

                    <!--
                        Bank accepted — Finance can register payment.
                    -->
                    <div class="alert alert-success" role="alert"
                         invisible="not clm_show_payment_action">
                        <strong>✅ Payment Ready</strong><br/>
                        Bank Acceptance is confirmed on one or more invoices.
                        Finance can now register payment on the related invoice(s).
                    </div>

                    <!-- Fully paid -->
                    <div class="alert alert-primary" role="alert"
                         invisible="clm_state != 'fully_paid'">
                        <strong>💰 Fully Paid</strong><br/>
                        All invoices for this order have been settled.
                        Exposure cleared from all credit buckets.
                    </div>

                    <!-- ════════════════════════════════════════════════════
                         B — CLM STAGE INFORMATION
                    ════════════════════════════════════════════════════ -->

                    <group string="CLM Operational Stage (SRS §2)">
                        <group>
                            <field name="clm_state"
                                   readonly="1"
                                   string="Current Stage"/>
                        </group>
                        <group>
                            <!-- Note: acceptance flags live on invoices now -->
                            <div class="text-muted small">
                                Customer Acceptance and Bank Acceptance are tracked
                                per invoice (SRS §4). Open the related invoice(s)
                                to view or record acceptance.
                            </div>
                        </group>
                    </group>

                </page>
            </xpath>

        </field>
    </record>
</odoo>