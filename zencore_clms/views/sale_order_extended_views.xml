<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_clm_statusbar" model="ir.ui.view">
        <field name="name">sale.order.form.clm.statusbar</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/field[@name='state'][@widget='statusbar']" position="replace">
                <field name="state" invisible="1"/>
                <field name="clm_state" widget="statusbar" statusbar_visible="pi,bucket1,bucket2,bucket3,bucket4,paid"/>
            </xpath>

            <!-- ── 2. Add acceptance buttons in header ── -->
            <xpath expr="//header/button[@name='action_confirm']" position="after">

                <!-- Customer Acceptance Button: visible only in Bucket 2 -->
                <button
                    name="action_clm_customer_acceptance"
                    type="object"
                    string="✔ Mark Customer Acceptance"
                    class="btn-primary"
                    invisible="not clm_show_customer_acceptance_btn"
                    confirm="Confirm that the customer has accepted the documents? This will move the order to Bucket 3."
                    groups="zencore_clms.group_zencore_clm_ccm,zencore_clms.group_zencore_clm_salesperson"
                />

                <!-- Bank Acceptance Button: visible only in Bucket 3 -->
                <button
                    name="action_clm_bank_acceptance"
                    type="object"
                    string="🏦 Mark Bank Acceptance"
                    class="btn-primary"
                    invisible="not clm_show_bank_acceptance_btn"
                    confirm="Confirm that the bank has accepted the documents? This will move the order to Bucket 4."
                    groups="zencore_clms.group_zencore_clm_ccm,zencore_clms.group_zencore_clm_finance"
                />

            </xpath>

            <xpath expr="//page[@name='order_lines']" position="before">
                <page string="Credit Control" name="clm_info">
                    <group>
                        <group string="Stage Information">
                            <field name="clm_state" readonly="1"/>
                            <field name="clm_customer_acceptance" readonly="1"/>
                            <field name="clm_bank_acceptance" readonly="1"/>
                        </group>
                        <group string="Customer Credit Status">
                            <field
                                name="partner_id"
                                widget="res_partner_many2one"
                                readonly="1"
                                string="Customer"
                            />
                        </group>
                    </group>

                    <!-- Payment availability notice -->
                    <div
                        class="alert alert-info"
                        invisible="not clm_show_payment_action"
                        role="alert"
                    >
                        <strong>Payment Ready:</strong> Bank acceptance has been confirmed.
                        You may now register payment on the related invoice.
                    </div>

                    <div
                        class="alert alert-warning"
                        invisible="clm_show_payment_action or clm_state == 'paid'"
                        role="alert"
                    >
                        <strong>Payment Locked:</strong> Payment registration is available
                        only after bank acceptance is recorded.
                    </div>

                </page>
            </xpath>
        </field>
    </record>
</odoo>

