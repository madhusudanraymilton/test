<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        CLM Tab on res.partner form.

        Logic:
          - Parent (group head, no parent_id): shows aggregated limits/balances + group freeze
          - Child customer (has parent_id): shows individual limits + balances + freeze status

        All limit fields are readonly — changes go through the approval workflow only.
        All balance fields are computed and readonly by nature.
    -->
    <record id="view_partner_form_clm" model="ir.ui.view">
        <field name="name">res.partner.form.clm</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook/page[@name='sales_purchases']" position="after">
                <page string="Credit Management" name="clm_credit">

                    <!-- ══════════════════════════════════════════════
                         CHILD CUSTOMER VIEW
                         Visible when: this contact has a parent (is a child in the group)
                         OR when partner has no children (standalone customer)
                    ══════════════════════════════════════════════ -->
                    <group string="Individual Credit Limits" invisible="child_ids">
                        <group string="Exposure Limits (set via approval workflow)">
                            <field name="clm_proforma_limit" readonly="1"/>
                            <field name="clm_bucket_1_limit" readonly="1"/>
                            <field name="clm_bucket_2_limit" readonly="1"/>
                            <field name="clm_bucket_3_limit" readonly="1"/>
                            <field name="clm_bucket_4_limit" readonly="1"/>
                        </group>
                        <group string="Current Exposure Balances">
                            <field name="clm_proforma_balance" readonly="1"/>
                            <field name="clm_bucket_1_balance" readonly="1"/>
                            <field name="clm_bucket_2_balance" readonly="1"/>
                            <field name="clm_bucket_3_balance" readonly="1"/>
                            <field name="clm_bucket_4_balance" readonly="1"/>
                        </group>
                    </group>

                    <!-- Freeze Status for individual customer -->
                    <group invisible="child_ids">
                        <field name="clm_is_frozen" readonly="1" widget="boolean_toggle"/>
                    </group>

                    <!-- ══════════════════════════════════════════════
                         PARENT / GROUP HEAD VIEW
                         Visible when: this partner has child contacts (is a group head)
                    ══════════════════════════════════════════════ -->
                    <group string="Group Aggregated Credit (Read-Only)" invisible="not child_ids">
                        <group string="Aggregated Limits">
                            <field name="clm_agg_proforma_limit" readonly="1"/>
                            <field name="clm_agg_bucket_1_limit" readonly="1"/>
                            <field name="clm_agg_bucket_2_limit" readonly="1"/>
                            <field name="clm_agg_bucket_3_limit" readonly="1"/>
                            <field name="clm_agg_bucket_4_limit" readonly="1"/>
                        </group>
                        <group string="Aggregated Balances">
                            <field name="clm_agg_proforma_balance" readonly="1"/>
                            <field name="clm_agg_bucket_1_balance" readonly="1"/>
                            <field name="clm_agg_bucket_2_balance" readonly="1"/>
                            <field name="clm_agg_bucket_3_balance" readonly="1"/>
                            <field name="clm_agg_bucket_4_balance" readonly="1"/>
                        </group>
                    </group>

                    <!-- Group Freeze Status for group head -->
                    <group invisible="not child_ids">
                        <field
                            name="clm_group_is_frozen"
                            readonly="1"
                            widget="boolean_toggle"
                            string="Group Frozen (any child breached)"
                        />
                    </group>

                </page>
            </xpath>

        </field>
    </record>

</odoo>