<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        CLM — res.partner form extensions (v1.0)

        Smart button bar (4 buttons):
          • Total Requests   → all history
          • Pending          → pending_fm only (most important for Finance)
          • Approved         → approved history
          • Rejected         → rejected history

        Credit Management tab:
          A. Freeze banners
          B. Individual limits + exposure (readonly)
          C. Active requests panel (embedded list — draft + pending_fm)
             CCM: "New Request" button
             Finance: click any row → form opens as dialog → Approve / Reject
          D. Group aggregate view (parent partners only)
    -->

    <!-- ══════════════════════════════════════════════════════════════════════
         SMART BUTTONS
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_partner_form_clm_smart_buttons" model="ir.ui.view">
        <field name="name">res.partner.form.clm.smart_buttons</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">

                <!-- Total requests -->
                <button
                    name="action_view_limit_requests"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-file-text-o"
                    invisible="clm_request_total_count == 0"
                    groups="zencore_clms.group_zencore_clm_ccm,zencore_clms.group_zencore_clm_finance,zencore_clms.group_zencore_clm_sales_manager"
                >
                    <field
                        name="clm_request_total_count"
                        widget="statinfo"
                        string="All Requests"
                    />
                </button>

                <!-- Pending FM — highlighted for Finance urgency -->
                <button
                    name="action_view_pending_requests"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-hourglass-half"
                    invisible="clm_request_pending_count == 0"
                    groups="zencore_clms.group_zencore_clm_finance,zencore_clms.group_zencore_clm_ccm"
                >
                    <field
                        name="clm_request_pending_count"
                        widget="statinfo"
                        string="Pending FM"
                    />
                </button>

                <!-- Approved history -->
                <button
                    name="action_view_limit_requests"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-check-circle"
                    invisible="clm_request_approved_count == 0"
                    groups="zencore_clms.group_zencore_clm_finance,zencore_clms.group_zencore_clm_sales_manager"
                >
                    <field
                        name="clm_request_approved_count"
                        widget="statinfo"
                        string="Approved"
                    />
                </button>

                <!-- Rejected history -->
                <button
                    name="action_view_limit_requests"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-times-circle"
                    invisible="clm_request_rejected_count == 0"
                    groups="zencore_clms.group_zencore_clm_finance,zencore_clms.group_zencore_clm_sales_manager"
                >
                    <field
                        name="clm_request_rejected_count"
                        widget="statinfo"
                        string="Rejected"
                    />
                </button>

            </xpath>
        </field>
    </record>


    <!-- ══════════════════════════════════════════════════════════════════════
         CREDIT MANAGEMENT TAB
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_partner_form_clm" model="ir.ui.view">
        <field name="name">res.partner.form.clm</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook/page[@name='sales_purchases']" position="after">
                <page
                    string="Credit Management"
                    name="clm_credit"
                    groups="zencore_clms.group_zencore_clm_ccm,zencore_clms.group_zencore_clm_finance,zencore_clms.group_zencore_clm_sales_manager"
                >

                    <!-- Hidden stat fields consumed by smart buttons -->
                    <field name="clm_request_total_count"    invisible="1"/>
                    <field name="clm_request_pending_count"  invisible="1"/>
                    <field name="clm_request_approved_count" invisible="1"/>
                    <field name="clm_request_rejected_count" invisible="1"/>

                    <!-- ════════════════════════════════════════════════════
                         A — FREEZE STATUS BANNERS
                    ════════════════════════════════════════════════════ -->

                    <div class="alert alert-danger" role="alert"
                         invisible="not clm_is_frozen or child_ids">
                        <strong>⛔ Credit Frozen:</strong>
                        This customer has exceeded at least one bucket limit.
                        New orders and deliveries are blocked until resolved.
                    </div>

                    <div class="alert alert-danger" role="alert"
                         invisible="not clm_group_is_frozen or not child_ids">
                        <strong>⛔ Group Credit Frozen:</strong>
                        One or more members of this group have exceeded a bucket limit.
                        All group members are blocked.
                    </div>


                    <!-- ════════════════════════════════════════════════════
                         B — INDIVIDUAL CREDIT LIMITS TABLE
                         Only for leaf / standalone partners (no children)
                    ════════════════════════════════════════════════════ -->
                    <group string="Individual Credit Limits" invisible="child_ids">
                        <group string="Limits (Approval Workflow Only)">
                            <field name="clm_proforma_limit" readonly="1"/>
                            <field name="clm_bucket_1_limit" readonly="1"/>
                            <field name="clm_bucket_2_limit" readonly="1"/>
                            <field name="clm_bucket_3_limit" readonly="1"/>
                            <field name="clm_bucket_4_limit" readonly="1"/>
                        </group>
                        <group string="Current Exposure (Real-Time)">
                            <field name="clm_proforma_balance" readonly="1"
                                   decoration-danger="clm_proforma_balance > clm_proforma_limit and clm_proforma_limit > 0"/>
                            <field name="clm_bucket_1_balance" readonly="1"
                                   decoration-danger="clm_bucket_1_balance > clm_bucket_1_limit and clm_bucket_1_limit > 0"/>
                            <field name="clm_bucket_2_balance" readonly="1"
                                   decoration-danger="clm_bucket_2_balance > clm_bucket_2_limit and clm_bucket_2_limit > 0"/>
                            <field name="clm_bucket_3_balance" readonly="1"
                                   decoration-danger="clm_bucket_3_balance > clm_bucket_3_limit and clm_bucket_3_limit > 0"/>
                            <field name="clm_bucket_4_balance" readonly="1"
                                   decoration-danger="clm_bucket_4_balance > clm_bucket_4_limit and clm_bucket_4_limit > 0"/>
                        </group>
                    </group>

                    <group invisible="child_ids">
                        <field name="clm_is_frozen" readonly="1"
                               widget="boolean_toggle" string="Credit Frozen"/>
                    </group>

                    <separator invisible="child_ids"/>


                    <!-- ════════════════════════════════════════════════════
                         C — ACTIVE LIMIT REQUESTS PANEL
                         Shown only for leaf / standalone partners.
                         clm_active_request_ids = domain-filtered O2M
                         showing only draft + pending_fm records.
                    ════════════════════════════════════════════════════ -->
                    <group string="Active Limit Change Requests" invisible="child_ids">

                        <!--
                            CCM: can create a new request from this button.
                            Finance / Sales Manager: no create button — they review only.
                        -->
                        <div class="mb-2"
                             groups="zencore_clms.group_zencore_clm_ccm">
                            <button
                                name="action_clm_new_limit_request"
                                type="object"
                                string="➕ New Limit Change Request"
                                class="btn btn-primary"
                            />
                        </div>

                        <!--
                            Finance hint — no active requests:
                            Shows only when no active (draft/pending) requests exist
                            and the user is Finance (so they understand why the list is empty).
                        -->
                        <div class="text-muted small mb-2"
                             invisible="clm_request_pending_count != 0 or clm_request_total_count == 0"
                             groups="zencore_clms.group_zencore_clm_finance">
                            No pending limit change requests for this customer.
                        </div>

                        <!--
                            Embedded active requests list.
                            clm_active_request_ids is filtered by domain at field
                            definition level: state in ('draft', 'pending_fm').

                            readonly="1" → prevents inline editing.
                            Clicking a row opens the form as a dialog where FM can
                            see the full detail and the Approve / Reject buttons.

                            Finance tip: Click any row below to open and approve/reject.
                        -->
                        <field
                            name="clm_active_request_ids"
                            readonly="1"
                            nolabel="1"
                            invisible="clm_request_total_count == 0"
                        >
                            <list
                                string="Active Requests"
                                decoration-warning="state == 'draft'"
                                decoration-info="state == 'pending_fm'"
                            >
                                <field name="name"         string="Reference"/>
                                <field
                                    name="request_type"
                                    widget="badge"
                                    decoration-danger="request_type == 'freeze_resolution'"
                                    decoration-info="request_type == 'standard_increase'"
                                />
                                <field name="state"        widget="badge"/>
                                <field name="initiated_by" string="Submitted By"/>
                                <field name="submitted_date" optional="show"/>
                                <field name="currency_id"  invisible="1"/>
                            </list>
                        </field>

                        <!-- History link — all requests including approved/rejected -->
                        <div class="mt-2"
                             invisible="clm_request_total_count == 0">
                            <button
                                name="action_view_limit_requests"
                                type="object"
                                string="📋 View Full Request History"
                                class="btn btn-link p-0"
                            />
                        </div>

                    </group>


                    <!-- ════════════════════════════════════════════════════
                         D — GROUP AGGREGATED VIEW
                         Only for group head partners (those with children)
                    ════════════════════════════════════════════════════ -->
                    <group string="Group Aggregated Credit (Sum of All Children)"
                           invisible="not child_ids">
                        <group string="Aggregated Limits">
                            <field name="clm_agg_proforma_limit"   readonly="1"/>
                            <field name="clm_agg_bucket_1_limit"   readonly="1"/>
                            <field name="clm_agg_bucket_2_limit"   readonly="1"/>
                            <field name="clm_agg_bucket_3_limit"   readonly="1"/>
                            <field name="clm_agg_bucket_4_limit"   readonly="1"/>
                        </group>
                        <group string="Aggregated Balances">
                            <field name="clm_agg_proforma_balance" readonly="1"/>
                            <field name="clm_agg_bucket_1_balance" readonly="1"/>
                            <field name="clm_agg_bucket_2_balance" readonly="1"/>
                            <field name="clm_agg_bucket_3_balance" readonly="1"/>
                            <field name="clm_agg_bucket_4_balance" readonly="1"/>
                        </group>
                    </group>

                    <group invisible="not child_ids">
                        <field name="clm_group_is_frozen"
                               readonly="1"
                               widget="boolean_toggle"
                               string="Group Frozen (any child breached)"/>
                    </group>

                </page>
            </xpath>

        </field>
    </record>

</odoo>