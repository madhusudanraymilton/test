<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        clm.limit.change.request — Views (v1.0)

        Changes from v0.6.1:
        ─────────────────────
        - state statusbar: added 'cancelled' stop
        - Cancel button added (CCM, draft state only)
        - FM overview menu re-added for Finance (all pending requests)
        - submitted_date column in list view
        - list view: pending filter shows partner aggregate count

        Access patterns:
        ─────────────────
        1. From partner Credit Management tab (inline embedded list)
        2. From partner smart button (full list filtered by partner)
        3. From Finance menu (all pending requests — company-wide)
    -->

    <!-- ══════════════════════════════════════════════════════════════════════
         FORM VIEW
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_clm_limit_change_request_form" model="ir.ui.view">
        <field name="name">clm.limit.change.request.form</field>
        <field name="model">clm.limit.change.request</field>
        <field name="arch" type="xml">
            <form string="Limit Change Request">

                <header>
                    <!-- CCM: draft → pending_fm -->
                    <button
                        name="action_submit_to_fm"
                        type="object"
                        string="Submit for FM Approval"
                        class="btn-primary"
                        invisible="state != 'draft'"
                        groups="zencore_clms.group_zencore_clm_ccm"
                    />

                    <!-- CCM: draft → cancelled -->
                    <button
                        name="action_cancel"
                        type="object"
                        string="Cancel Request"
                        invisible="state != 'draft'"
                        groups="zencore_clms.group_zencore_clm_ccm"
                        confirm="Cancel this draft? The request cannot be reopened."
                    />

                    <!-- Finance: pending_fm → approved -->
                    <button
                        name="action_approve"
                        type="object"
                        string="✔ Approve"
                        class="btn-success"
                        invisible="state != 'pending_fm'"
                        groups="zencore_clms.group_zencore_clm_finance"
                        confirm="Approve? All proposed limits will be applied to the customer immediately."
                    />

                    <!-- Finance: pending_fm → rejected -->
                    <button
                        name="action_reject"
                        type="object"
                        string="✗ Reject"
                        class="btn-danger"
                        invisible="state != 'pending_fm'"
                        groups="zencore_clms.group_zencore_clm_finance"
                        confirm="Reject this request? This action is permanent."
                    />

                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,pending_fm,approved,rejected"
                    />
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- Classification banners -->
                    <div class="alert alert-danger" role="alert"
                         invisible="request_type != 'freeze_resolution'">
                        <strong>⚠ Freeze Resolution:</strong>
                        One or more buckets have exposure exceeding the current limit.
                        Approving will raise the limit to cover the breach.
                    </div>
                    <div class="alert alert-info" role="alert"
                         invisible="request_type != 'standard_increase'">
                        <strong>ℹ Standard Increase:</strong>
                        No active breach detected on any requested bucket.
                    </div>

                    <!-- Request details -->
                    <group>
                        <group string="Request Details">
                            <field name="partner_id"   readonly="state != 'draft'"/>
                            <field name="request_type" readonly="1"/>
                            <field name="currency_id"  invisible="1"/>
                        </group>
                        <group string="Audit Trail" invisible="state == 'draft'">
                            <field name="initiated_by"  readonly="1"/>
                            <field name="submitted_date" readonly="1"
                                   invisible="not submitted_date"/>
                            <field name="reviewed_by"    readonly="1"
                                   invisible="state in ('draft', 'pending_fm')"/>
                            <field name="reviewed_date"  readonly="1"
                                   invisible="state in ('draft', 'pending_fm')"/>
                        </group>
                    </group>

                    <!-- Justification -->
                    <group string="Justification">
                        <field
                            name="justification"
                            nolabel="1"
                            readonly="state != 'draft'"
                            placeholder="Provide business justification for this limit change request..."
                        />
                    </group>

                    <!-- FM Comment — visible from pending_fm onwards -->
                    <group string="Finance Manager Comment"
                           invisible="state == 'draft'">
                        <field
                            name="fm_comment"
                            nolabel="1"
                            readonly="state != 'pending_fm'"
                            placeholder="Required for rejection. Optional for approval."
                        />
                    </group>

                    <!-- Bucket Lines -->
                    <notebook>
                        <page string="Bucket Limit Lines" name="limit_lines">

                            <div class="alert alert-info mb-2" role="alert"
                                 invisible="state != 'draft'">
                                <strong>ℹ</strong>
                                All 5 buckets are auto-filled when you select a customer.
                                Edit only the <b>Proposed Limit</b> for buckets you want to change.
                                Buckets where Proposed = Current are skipped at approval.
                            </div>

                            <field
                                name="line_ids"
                                readonly="state != 'draft'"
                            >
                                <list
                                    editable="bottom"
                                    create="0"
                                    delete="0"
                                >
                                    <!--
                                        bucket is readonly="1" in the view.
                                        DO NOT remove this — it must match the model-level
                                        constraint that bucket is not user-editable.
                                        The create() override sets bucket server-side.
                                    -->
                                    <field name="bucket"           readonly="1"/>
                                    <field name="current_limit"    readonly="1"/>
                                    <field
                                        name="current_exposure"
                                        readonly="1"
                                        decoration-danger="current_exposure > current_limit and current_limit > 0"
                                        decoration-muted="current_limit == 0"
                                    />
                                    <field
                                        name="proposed_limit"
                                        
                                    />
                                    <field
                                        name="request_type"
                                        widget="badge"
                                        readonly="1"
                                        decoration-danger="request_type == 'freeze_resolution'"
                                        decoration-info="request_type == 'standard_increase'"
                                    />
                                    <field
                                        name="previous_limit"
                                        readonly="1"
                                        optional="show"
                                        column_invisible="parent.state not in ('approved',)"
                                    />
                                </list>
                            </field>

                        </page>
                    </notebook>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <!-- ══════════════════════════════════════════════════════════════════════
         LIST VIEW
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_clm_limit_change_request_list" model="ir.ui.view">
        <field name="name">clm.limit.change.request.list</field>
        <field name="model">clm.limit.change.request</field>
        <field name="arch" type="xml">
            <list
                string="Limit Change Requests"
                decoration-danger="state in ('rejected', 'cancelled')"
                decoration-success="state == 'approved'"
                decoration-warning="state == 'pending_fm'"
                decoration-muted="state == 'cancelled'"
            >
                <field name="name"/>
                <field name="partner_id"/>
                <field
                    name="request_type"
                    widget="badge"
                    decoration-danger="request_type == 'freeze_resolution'"
                    decoration-info="request_type == 'standard_increase'"
                />
                <field name="initiated_by"/>
                <field name="submitted_date" optional="show"/>
                <field name="state"          widget="badge"/>
                <field name="reviewed_by"    optional="show"/>
                <field name="reviewed_date"  optional="show"/>
                <field name="currency_id"    invisible="1"/>
            </list>
        </field>
    </record>


    <!-- ══════════════════════════════════════════════════════════════════════
         SEARCH VIEW
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_clm_limit_change_request_search" model="ir.ui.view">
        <field name="name">clm.limit.change.request.search</field>
        <field name="model">clm.limit.change.request</field>
        <field name="arch" type="xml">
            <search string="Limit Change Requests">
                <field name="name"       string="Reference"/>
                <field name="partner_id" string="Customer"/>
                <filter string="My Requests" name="my"
                        domain="[('initiated_by', '=', uid)]"/>
                <separator/>
                <filter string="Draft"     name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Pending FM" name="pending"
                        domain="[('state', '=', 'pending_fm')]"/>
                <filter string="Approved"  name="approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected"  name="rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="Freeze Resolution" name="freeze"
                        domain="[('request_type', '=', 'freeze_resolution')]"/>
                <separator/>
                <filter string="Customer" name="grp_partner"
                        context="{'group_by': 'partner_id'}"/>
                <filter string="Status"   name="grp_state"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>


    <!-- ══════════════════════════════════════════════════════════════════════
         WINDOW ACTIONS
    ══════════════════════════════════════════════════════════════════════ -->

    <!-- General action — used by smart button and partner form -->
    <record id="action_clm_limit_change_request" model="ir.actions.act_window">
        <field name="name">Limit Change Requests</field>
        <field name="res_model">clm.limit.change.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_clm_limit_change_request_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No limit change requests found.</p>
            <p>
                Limit change requests are submitted from the customer's
                <b>Credit Management</b> tab by the CCM role.
            </p>
        </field>
    </record>

    <!-- Finance-specific action — pre-filtered to pending_fm only -->
    <record id="action_clm_pending_requests_finance" model="ir.actions.act_window">
        <field name="name">Pending FM Approvals</field>
        <field name="res_model">clm.limit.change.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'pending_fm')]</field>
        <field name="search_view_id" ref="view_clm_limit_change_request_search"/>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No pending requests awaiting approval.</p>
        </field>
    </record>


    <!-- ══════════════════════════════════════════════════════════════════════
         MENU — Finance can access all pending requests directly
         (removed in v0.6.0, restored in v1.0 for Finance overview)
    ══════════════════════════════════════════════════════════════════════ -->

    <!-- Root menu (visible to Finance and CCM) -->
    <menuitem
        id="menu_clm_root"
        name="Credit Limits"
        sequence="55"
        groups="zencore_clms.group_zencore_clm_finance,zencore_clms.group_zencore_clm_ccm"
    />

    <!-- Finance: overview of all pending approvals -->
    <menuitem
        id="menu_clm_pending_approvals"
        name="Pending FM Approvals"
        parent="menu_clm_root"
        action="action_clm_pending_requests_finance"
        sequence="10"
        groups="zencore_clms.group_zencore_clm_finance"
    />

    <!-- Finance + CCM: full request history -->
    <menuitem
        id="menu_clm_all_requests"
        name="All Limit Requests"
        parent="menu_clm_root"
        action="action_clm_limit_change_request"
        sequence="20"
        groups="zencore_clms.group_zencore_clm_finance,zencore_clms.group_zencore_clm_ccm"
    />

<!--
    Add this block to the BOTTOM of clm_limit_change_request_views.xml
    (just before the closing </odoo> tag).

    Alternatively, register this as a separate file in __manifest__.py
    under 'data' (after the existing views file):
        'views/clm_bulk_actions_views.xml',
-->


    <!-- ══════════════════════════════════════════════════════════════════════
         BULK REJECT WIZARD — Form View
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_clm_bulk_reject_wizard_form" model="ir.ui.view">
        <field name="name">clm.bulk.reject.wizard.form</field>
        <field name="model">clm.bulk.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Reject — Limit Change Requests">

                <sheet>

                    <!-- Summary banner — shows counts so Finance knows what they are rejecting -->
                    <div class="alert alert-warning" role="alert">
                        <strong>⚠ Bulk Rejection</strong><br/>
                        You are about to reject
                        <strong><field name="pending_count" readonly="1" nolabel="1"/></strong>
                        pending request(s).

                        <!-- Warn if some selected records are not pending -->
                        <span invisible="skipped_count == 0">
                            <br/>
                            <strong>
                                <field name="skipped_count" readonly="1" nolabel="1"/>
                                record(s)
                            </strong>
                            will be <em>skipped</em> (not in Pending FM state).
                        </span>
                    </div>

                    <!-- Requests being rejected (readonly list for audit clarity) -->
                    <group string="Requests to Reject">
                        <field
                            name="request_ids"
                            readonly="1"
                            nolabel="1"
                        >
                            <list string="Selected Requests">
                                <field name="name"         string="Reference"/>
                                <field name="partner_id"   string="Customer"/>
                                <field name="request_type" widget="badge"
                                       decoration-danger="request_type == 'freeze_resolution'"
                                       decoration-info="request_type == 'standard_increase'"/>
                                <field name="initiated_by" string="Submitted By"/>
                                <field name="state"        widget="badge"/>
                                <field name="currency_id"  invisible="1"/>
                            </list>
                        </field>
                    </group>

                    <!-- Required rejection reason — shared across all records -->
                    <group string="Rejection Reason (applied to all selected requests)">
                        <field
                            name="fm_comment"
                            nolabel="1"
                            placeholder="Enter the rejection reason. This will be recorded on all selected requests..."
                            required="1"
                        />
                    </group>

                </sheet>

                <footer>
                    <button
                        name="action_confirm_reject"
                        type="object"
                        string="✗ Confirm Rejection"
                        class="btn-danger"
                        data-hotkey="q"
                        confirm="This will permanently reject all selected pending requests. Continue?"
                    />
                    <button
                        string="Cancel"
                        class="btn-secondary"
                        special="cancel"
                        data-hotkey="z"
                    />
                </footer>

            </form>
        </field>
    </record>


    <!-- ══════════════════════════════════════════════════════════════════════
         SERVER ACTIONS — Bound to list view (appear in Action dropdown)
         Only Finance users see these (groups restriction on the action).

         Odoo 19 note:
           binding_model_id  = which model's list view shows this action
           binding_view_types = 'list' → appears ONLY in list view Action menu
           groups_ext_id     = restricts visibility to the specified group
    ══════════════════════════════════════════════════════════════════════ -->

    <!-- Bulk Approve -->
    <record id="action_server_clm_bulk_approve" model="ir.actions.server">
        <field name="name">✔ Approve Selected</field>
        <field name="model_id" ref="model_clm_limit_change_request"/>
        <field name="binding_model_id" ref="model_clm_limit_change_request"/>
        <field name="binding_view_types">list</field>
        <field name="groups_ext_id">zencore_clms.group_zencore_clm_finance</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_bulk_approve()
        </field>
    </record>

    <!-- Bulk Reject (opens wizard) -->
    <record id="action_server_clm_bulk_reject" model="ir.actions.server">
        <field name="name">✗ Reject Selected</field>
        <field name="model_id" ref="model_clm_limit_change_request"/>
        <field name="binding_model_id" ref="model_clm_limit_change_request"/>
        <field name="binding_view_types">list</field>
        <field name="groups_ext_id">zencore_clms.group_zencore_clm_finance</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_open_bulk_reject_wizard()
        </field>
    </record>

</odoo>