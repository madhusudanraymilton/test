<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        clm.limit.change.request — Views (v0.6.0)

        Changes from v0.5.0:
        ─────────────────────
        - Menu items REMOVED. Access is now exclusively via:
            1. Partner Credit Management tab buttons (inline workflow)
            2. Partner smart button → list view → form view
        - Form view: added fm_comment field visibility in 'pending_fm' state
          even for Finance when opened via reject dialog (clm_reject_mode context).
        - Form and list views retained in full for dialog and smart button use.

        Dialog behaviour (target='new'):
        ──────────────────────────────────
        The form opens as a modal dialog when called from the partner form.
        Standard Odoo modal behaviour applies — Save closes and refreshes parent.
    -->

    <!-- ══════════════════════════════════════════════════════════════════════
         FORM VIEW
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_clm_limit_change_request_form" model="ir.ui.view">
        <field name="name">clm.limit.change.request.form</field>
        <field name="model">clm.limit.change.request</field>
        <field name="arch" type="xml">
            <form string="Limit Change Request">

                <!-- ── HEADER ─────────────────────────────────────────── -->
                <header>

                    <!-- CCM: draft → pending_fm -->
                    <button
                        name="action_submit_to_fm"
                        type="object"
                        string="Submit for FM Approval"
                        class="btn-primary"
                        invisible="state != 'draft'"
                        groups="zencore_clms.group_zencore_clm_ccm"
                    />

                    <!-- Finance: pending_fm → approved -->
                    <button
                        name="action_approve"
                        type="object"
                        string="✔ Approve"
                        class="btn-success"
                        invisible="state != 'pending_fm'"
                        groups="zencore_clms.group_zencore_clm_finance"
                        confirm="This will immediately update all bucket limits on the customer. Proceed?"
                    />

                    <!-- Finance: pending_fm → rejected -->
                    <button
                        name="action_reject"
                        type="object"
                        string="✗ Reject"
                        class="btn-danger"
                        invisible="state != 'pending_fm'"
                        groups="zencore_clms.group_zencore_clm_finance"
                        confirm="Reject this request? This action is permanent and cannot be undone."
                    />

                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,pending_fm,approved,rejected"
                    />

                </header>

                <!-- ── SHEET ──────────────────────────────────────────── -->
                <sheet>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- ── Classification Banners ── -->
                    <div
                        class="alert alert-danger"
                        invisible="request_type != 'freeze_resolution'"
                        role="alert"
                    >
                        <strong>⚠ Freeze Resolution Request:</strong>
                        One or more buckets have exposure exceeding the current limit.
                        Approving this request will raise the limit to cover the exposure.
                    </div>
                    <div
                        class="alert alert-info"
                        invisible="request_type != 'standard_increase'"
                        role="alert"
                    >
                        <strong>ℹ Standard Limit Increase:</strong>
                        No active breach detected on any requested bucket.
                    </div>

                    <!-- ── Reject Mode Banner (context flag from partner action) ── -->
                    <div
                        class="alert alert-warning"
                        invisible="not context.get('clm_reject_mode')"
                        role="alert"
                    >
                        <strong>Rejection Mode:</strong>
                        Enter your rejection reason in the Finance Manager Comment field below,
                        then click <b>✗ Reject</b>.
                    </div>

                    <!-- ── Request Details ── -->
                    <group>
                        <group string="Request Details">
                            <field name="partner_id"   readonly="state != 'draft'"/>
                            <field name="request_type" readonly="1"/>
                            <field name="currency_id"  invisible="1"/>
                        </group>
                        <group string="Audit Trail" invisible="state == 'draft'">
                            <field name="initiated_by"  readonly="1"/>
                            <field name="reviewed_by"   readonly="1"
                                   invisible="state in ('draft','pending_fm')"/>
                            <field name="reviewed_date" readonly="1"
                                   invisible="state in ('draft','pending_fm')"/>
                        </group>
                    </group>

                    <!-- ── Justification ── -->
                    <group string="Justification">
                        <field
                            name="justification"
                            nolabel="1"
                            readonly="state != 'draft'"
                            placeholder="Provide business justification for this limit change request..."
                        />
                    </group>

                    <!-- ── Finance Manager Comment ── -->
                    <!--
                        Visible when:
                          - state is pending_fm (Finance needs to enter before reject)
                          - state is approved / rejected (audit trail)
                        Hidden in draft state.
                    -->
                    <group
                        string="Finance Manager Comment"
                        invisible="state == 'draft'"
                    >
                        <field
                            name="fm_comment"
                            nolabel="1"
                            readonly="state not in ('pending_fm',)"
                            placeholder="Required for rejection. Optional for approval."
                        />
                    </group>

                    <!-- ── Notebook: Bucket Lines ── -->
                    <notebook>
                        <page string="Bucket Limit Lines" name="limit_lines">

                            <div class="alert alert-info mb-3" role="alert"
                                 invisible="state != 'draft'">
                                <strong>ℹ All 5 buckets are auto-filled when you select a customer.</strong>
                                Only edit the <b>Proposed Limit</b> for buckets you want to change.
                                Buckets where Proposed = Current have no effect on approval.
                            </div>

                            <field
                                name="line_ids"
                                readonly="state != 'draft'"
                            >
                                <list
                                    editable="bottom"
                                    create="0"
                                    delete="0"
                                >
                                    <field name="bucket"           readonly="1"/>
                                    <field name="current_limit"    readonly="1" string="Current Limit"/>
                                    <field
                                        name="current_exposure"
                                        readonly="1"
                                        string="Current Exposure"
                                        decoration-danger="current_exposure > current_limit and current_limit > 0"
                                        decoration-muted="current_limit == 0"
                                    />
                                    <field
                                        name="proposed_limit"
                                        string="Proposed Limit"
                                        decoration-warning="proposed_limit != current_limit"
                                    />
                                    <field
                                        name="request_type"
                                        widget="badge"
                                        readonly="1"
                                        decoration-danger="request_type == 'freeze_resolution'"
                                        decoration-info="request_type == 'standard_increase'"
                                        string="Type"
                                    />
                                    <field
                                        name="previous_limit"
                                        readonly="1"
                                        optional="show"
                                        column_invisible="parent.state not in ('approved',)"
                                        string="Previous Limit"
                                    />
                                </list>
                            </field>

                        </page>
                    </notebook>

                </sheet>

                <chatter/>
            </form>
        </field>
    </record>


    <!-- ══════════════════════════════════════════════════════════════════════
         LIST VIEW — Used by smart button and action_view_limit_requests
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_clm_limit_change_request_list" model="ir.ui.view">
        <field name="name">clm.limit.change.request.list</field>
        <field name="model">clm.limit.change.request</field>
        <field name="arch" type="xml">
            <list
                string="Limit Change Requests"
                decoration-danger="state == 'rejected'"
                decoration-success="state == 'approved'"
                decoration-warning="state == 'pending_fm'"
            >
                <field name="name"/>
                <field name="partner_id"/>
                <field
                    name="request_type"
                    widget="badge"
                    decoration-danger="request_type == 'freeze_resolution'"
                    decoration-info="request_type == 'standard_increase'"
                />
                <field name="initiated_by"/>
                <field name="state"         widget="badge"/>
                <field name="reviewed_by"   optional="show"/>
                <field name="reviewed_date" optional="show"/>
                <field name="currency_id"   invisible="1"/>
            </list>
        </field>
    </record>


    <!-- ══════════════════════════════════════════════════════════════════════
         SEARCH VIEW
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_clm_limit_change_request_search" model="ir.ui.view">
        <field name="name">clm.limit.change.request.search</field>
        <field name="model">clm.limit.change.request</field>
        <field name="arch" type="xml">
            <search string="Limit Change Requests">

                <field name="name"       string="Reference"/>
                <field name="partner_id" string="Customer"/>

                <filter string="My Requests"    name="my_requests"    domain="[('initiated_by', '=', uid)]"/>
                <separator/>
                <filter string="Draft"          name="draft"          domain="[('state', '=', 'draft')]"/>
                <filter string="Pending FM"     name="pending_fm"     domain="[('state', '=', 'pending_fm')]"/>
                <filter string="Approved"       name="approved"       domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected"       name="rejected"       domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="Freeze Resolution" name="freeze_resolution" domain="[('request_type', '=', 'freeze_resolution')]"/>
                <separator/>
                <filter string="Customer"       name="group_partner"  context="{'group_by': 'partner_id'}"/>
                <filter string="Status"         name="group_state"    context="{'group_by': 'state'}"/>

            </search>
        </field>
    </record>


    <!-- ══════════════════════════════════════════════════════════════════════
         WINDOW ACTION — Used by smart button + action_view_limit_requests()
         No menuitem — access is via partner form only.
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="action_clm_limit_change_request" model="ir.actions.act_window">
        <field name="name">Limit Change Requests</field>
        <field name="res_model">clm.limit.change.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_clm_limit_change_request_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No limit change requests found.
            </p>
            <p>
                Limit change requests are submitted from the customer's
                <b>Credit Management</b> tab by the CCM role.
            </p>
        </field>
    </record>

    <!--
        ══════════════════════════════════════════════════════════════════════
        MENU ITEMS — REMOVED in v0.6.0.

        Rationale:
          All limit management is now driven from the partner Credit Management
          tab. There is no need for a standalone CLM navigation menu.
          Finance users access pending requests via:
            1. The partner Credit Management tab (approve/reject buttons)
            2. The partner smart button (full request history)

        If a standalone Finance overview is needed in future, re-add:
            <menuitem id="menu_clm_credit_management" .../>
            <menuitem id="menu_clm_limit_requests"    .../>
        ══════════════════════════════════════════════════════════════════════
    -->

</odoo>