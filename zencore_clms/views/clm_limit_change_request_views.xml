<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         FORM VIEW
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_clm_limit_change_request_form" model="ir.ui.view">
        <field name="name">clm.limit.change.request.form</field>
        <field name="model">clm.limit.change.request</field>
        <field name="arch" type="xml">
            <form string="Limit Change Request">
                <header>

                    <!-- CCM submits draft → pending_fm -->
                    <button
                        name="action_submit_to_fm"
                        type="object"
                        string="Submit for FM Approval"
                        class="btn-primary"
                        invisible="state != 'draft'"
                        groups="zencore_clms.group_zencore_clm_ccm"
                    />

                    <!-- FM approves pending_fm → approved -->
                    <button
                        name="action_approve"
                        type="object"
                        string="✔ Approve"
                        class="btn-success"
                        invisible="state != 'pending_fm'"
                        groups="zencore_clms.group_zencore_clm_finance"
                        confirm="This will immediately update the customer's credit limit. Proceed?"
                    />

                    <!-- FM rejects pending_fm → rejected -->
                    <button
                        name="action_reject"
                        type="object"
                        string="✗ Reject"
                        class="btn-danger"
                        invisible="state != 'pending_fm'"
                        groups="zencore_clms.group_zencore_clm_finance"
                        confirm="Reject this request? This action is permanent and cannot be undone."
                    />

                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,pending_fm,approved,rejected"
                    />
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- Classification banners -->
                    <div
                        class="alert alert-danger"
                        invisible="request_type != 'freeze_resolution'"
                        role="alert"
                    >
                        <strong>⚠ Freeze Resolution Request:</strong>
                        Current exposure exceeds the limit. Approval will resolve the freeze if
                        the new limit covers the current exposure.
                    </div>
                    <div
                        class="alert alert-info"
                        invisible="request_type != 'standard_increase'"
                        role="alert"
                    >
                        <strong>ℹ Standard Limit Increase:</strong>
                        No active breach on this bucket.
                    </div>

                    <group>
                        <group string="Request Details">
                            <field name="partner_id"    readonly="state != 'draft'"/>
                            <field name="bucket"        readonly="state != 'draft'"/>
                            <field name="request_type"  readonly="1"/>
                            <field name="currency_id"   invisible="1"/>
                        </group>
                        <group string="Limit Values">
                            <field name="current_limit"    readonly="1"/>
                            <field name="current_exposure" readonly="1"/>
                            <field name="proposed_limit"   readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <group string="Justification">
                        <field
                            name="justification"
                            nolabel="1"
                            readonly="state != 'draft'"
                            placeholder="Provide business justification for this limit change..."
                        />
                    </group>

                    <!-- FM comment — visible from pending_fm onward -->
                    <group
                        string="Finance Manager Comment"
                        invisible="state == 'draft'"
                    >
                        <field
                            name="fm_comment"
                            nolabel="1"
                            readonly="state not in ('pending_fm',)"
                            placeholder="Required for rejection. Optional for approval."
                        />
                    </group>

                    <!-- Audit trail — shown after FM action -->
                    <group
                        string="Audit Trail"
                        invisible="state in ('draft', 'pending_fm')"
                    >
                        <field name="initiated_by"   readonly="1"/>
                        <field name="reviewed_by"    readonly="1"/>
                        <field name="reviewed_date"  readonly="1"/>
                        <field name="previous_limit" readonly="1"/>
                    </group>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         LIST VIEW
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_clm_limit_change_request_list" model="ir.ui.view">
        <field name="name">clm.limit.change.request.list</field>
        <field name="model">clm.limit.change.request</field>
        <field name="arch" type="xml">
            <list
                string="Limit Change Requests"
                decoration-danger="state == 'rejected'"
                decoration-success="state == 'approved'"
                decoration-warning="state == 'pending_fm'"
            >
                <field name="name"/>
                <field name="partner_id"/>
                <field name="bucket"/>
                <field name="request_type" widget="badge"/>
                <field name="current_limit"/>
                <field name="proposed_limit"/>
                <field name="initiated_by"/>
                <field name="state" widget="badge"/>
                <field name="reviewed_date"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         SEARCH VIEW
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_clm_limit_change_request_search" model="ir.ui.view">
        <field name="name">clm.limit.change.request.search</field>
        <field name="model">clm.limit.change.request</field>
        <field name="arch" type="xml">
            <search string="Limit Change Requests">
                <field name="name"       string="Reference"/>
                <field name="partner_id" string="Customer"/>
                <filter string="My Requests"    name="my_requests"       domain="[('initiated_by', '=', uid)]"/>
                <separator/>
                <filter string="Draft"          name="draft"             domain="[('state', '=', 'draft')]"/>
                <filter string="Pending FM"     name="pending_fm"        domain="[('state', '=', 'pending_fm')]"/>
                <filter string="Approved"       name="approved"          domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected"       name="rejected"          domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter
                    string="Freeze Resolution"
                    name="freeze_resolution"
                    domain="[('request_type', '=', 'freeze_resolution')]"
                />
                <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                <filter string="Bucket"   name="group_bucket"  context="{'group_by': 'bucket'}"/>
                <filter string="Status"   name="group_state"   context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         WINDOW ACTION
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="action_clm_limit_change_request" model="ir.actions.act_window">
        <field name="name">Limit Change Requests</field>
        <field name="res_model">clm.limit.change.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_clm_limit_change_request_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No limit change requests found.
            </p>
            <p>
                Create a request to propose a credit limit change for a customer bucket.
                Requests require Finance Manager approval before taking effect.
                Only CCM may submit requests. Finance Manager approves or rejects.
            </p>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         MENU ITEMS
    ══════════════════════════════════════════════════════════════════════ -->
    <menuitem
        id="menu_clm_credit_management"
        name="Credit Management"
        parent="sale.sale_menu_root"
        sequence="60"
        groups="zencore_clms.group_zencore_clm_ccm,zencore_clms.group_zencore_clm_finance,zencore_clms.group_zencore_clm_sales_manager"
    />
    <menuitem
        id="menu_clm_limit_requests"
        name="Limit Change Requests"
        parent="menu_clm_credit_management"
        action="action_clm_limit_change_request"
        sequence="10"
        groups="zencore_clms.group_zencore_clm_ccm,zencore_clms.group_zencore_clm_finance,zencore_clms.group_zencore_clm_sales_manager"
    />

