<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="asset_management_bdcalling.AssetDashboard">
        <div class="o_asset_dashboard container-fluid">

            <!-- HEADER -->
            <div class="o_asset_dashboard_header d-flex justify-content-between align-items-center py-3 mb-4 border-bottom">
                <h3 class="fw-bold text-primary">Asset Management Dashboard</h3>

                <button class="btn btn-outline-primary btn-sm d-flex align-items-center" t-on-click="refresh">
                    <i class="fa fa-refresh me-2"/>
                    Refresh
                </button>
            </div>

            <!-- LOADING STATE -->
            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                    <i class="fa fa-spinner fa-spin fa-3x text-primary me-3"/>
                    <p class="fs-5 mb-0">Loading dashboard...</p>
                </div>
            </t>

            <!-- DASHBOARD CONTENT -->
            <t t-else="">
                <div class="o_asset_dashboard_content">

                    <!-- KPI ROW -->
                    <div class="row g-4 mb-4">

                        <!-- TOTAL ASSETS -->
                        <div class="col-xl-3 col-md-6">
                            <div class="card ams-kpi-card shadow-sm hover-scale" t-on-click="openAllAssets">
                                <div class="card-body d-flex align-items-center">
                                    <div class="ams-kpi-icon bg-gradient-primary text-white me-3">
                                        <i class="fa fa-cubes fa-2x"/>
                                    </div>
                                    <div class="ams-kpi-data">
                                        <div class="ams-kpi-number fs-4 fw-bold">
                                            <t t-esc="state.total"/>
                                        </div>
                                        <div class="ams-kpi-label text-muted small">
                                            Total Assets
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- AVAILABLE -->
                        <div class="col-xl-3 col-md-6">
                            <div class="card ams-kpi-card shadow-sm hover-scale" t-on-click="openAvailableAssets">
                                <div class="card-body d-flex align-items-center">
                                    <div class="ams-kpi-icon bg-gradient-success text-white me-3">
                                        <i class="fa fa-check fa-2x"/>
                                    </div>
                                    <div class="ams-kpi-data">
                                        <div class="ams-kpi-number fs-4 fw-bold">
                                            <t t-esc="state.available"/>
                                        </div>
                                        <div class="ams-kpi-label text-muted small">
                                            Available Assets
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ASSIGNED -->
                        <div class="col-xl-3 col-md-6">
                            <div class="card ams-kpi-card shadow-sm hover-scale" t-on-click="openAssignedAssets">
                                <div class="card-body d-flex align-items-center">
                                    <div class="ams-kpi-icon bg-gradient-info text-white me-3">
                                        <i class="fa fa-user fa-2x"/>
                                    </div>
                                    <div class="ams-kpi-data">
                                        <div class="ams-kpi-number fs-4 fw-bold">
                                            <t t-esc="state.assigned"/>
                                        </div>
                                        <div class="ams-kpi-label text-muted small">
                                            Assigned Assets
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SCRAPPED -->
                        <div class="col-xl-3 col-md-6">
                            <div class="card ams-kpi-card shadow-sm hover-scale">
                                <div class="card-body d-flex align-items-center">
                                    <div class="ams-kpi-icon bg-gradient-danger text-white me-3">
                                        <i class="fa fa-trash fa-2x"/>
                                    </div>
                                    <div class="ams-kpi-data">
                                        <div class="ams-kpi-number fs-4 fw-bold">
                                            <t t-esc="state.scrapped_disposed"/>
                                        </div>
                                        <div class="ams-kpi-label text-muted small">
                                            Scrapped
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- SECOND ROW -->
                    <div class="row g-4 mb-4">

                        <!-- CATEGORY CHART -->
                        <div class="col-lg-8">
                            <div class="card shadow-sm">
                                <div class="card-header bg-white border-bottom">
                                    <h6 class="fw-bold mb-0">Assets by Category</h6>
                                </div>
                                <div class="card-body">
                                    <canvas id="categoryChart" style="height: 300px;"/>
                                </div>
                            </div>
                        </div>

                        <!-- STATUS BREAKDOWN -->
                        <div class="col-lg-4">
                            <div class="card shadow-sm">
                                <div class="card-header bg-white border-bottom">
                                    <h6 class="fw-bold mb-0">Status Breakdown</h6>
                                </div>
                                <div class="card-body">
                                    <ul class="list-group list-group-flush ams-status-list">
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <span class="badge bg-gradient-success">Available</span>
                                            <span t-esc="state.available"/>
                                        </li>
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <span class="badge bg-gradient-info">Assigned</span>
                                            <span t-esc="state.assigned"/>
                                        </li>
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <span class="badge bg-gradient-danger">Scrapped</span>
                                            <span t-esc="state.scrapped_disposed"/>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- RECENT ASSIGNMENTS -->
                    <div class="card shadow-sm">
                        <div class="card-header bg-white border-bottom">
                            <h6 class="fw-bold mb-0">Recent Assignments</h6>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover table-striped mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Asset</th>
                                            <th>Employee</th>
                                            <th>Date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.recent_assignments" t-as="rec" t-key="rec.id">
                                            <tr class="align-middle">
                                                <td><t t-esc="rec.asset"/></td>
                                                <td><t t-esc="rec.employee"/></td>
                                                <td><t t-esc="rec.date"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
            </t>

        </div>

        <!-- STYLES -->
        <style>
            .ams-kpi-card {
                cursor: pointer;
                border-radius: 0.5rem;
                transition: transform 0.2s, box-shadow 0.2s;
            }
            .ams-kpi-card .ams-kpi-icon {
                width: 60px;
                height: 60px;
                display: flex;
                justify-content: center;
                align-items: center;
                border-radius: 0.75rem;
            }
            .hover-scale:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            }
            .bg-gradient-primary { background: linear-gradient(135deg, #4e73df, #224abe); }
            .bg-gradient-success { background: linear-gradient(135deg, #1cc88a, #17a673); }
            .bg-gradient-info { background: linear-gradient(135deg, #36b9cc, #2c9faf); }
            .bg-gradient-danger { background: linear-gradient(135deg, #e74a3b, #c0392b); }
            .ams-status-list .badge {
                font-size: 0.9rem;
            }
        </style>
    </t>
</templates>