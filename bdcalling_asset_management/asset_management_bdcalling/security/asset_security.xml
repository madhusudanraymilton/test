<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- GROUPS                                                              -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <record id="group_asset_user" model="res.groups">
        <field name="name">Asset User</field>
        <!-- <field name="category_id" ref="base.module_category_accounting_accounting"/> -->
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_asset_officer" model="res.groups">
        <field name="name">Asset Officer</field>
        <!-- <field name="category_id" ref="base.module_category_accounting_accounting"/> -->
        <field name="implied_ids" eval="[(4, ref('asset_management_bdcalling.group_asset_user'))]"/>
    </record>

    <record id="group_asset_manager" model="res.groups">
        <field name="name">Asset Manager</field>
        <!-- <field name="category_id" ref="base.module_category_accounting_accounting"/> -->
        <field name="implied_ids" eval="[(4, ref('asset_management_bdcalling.group_asset_officer'))]"/>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- RECORD RULES — Multi-company isolation                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- asset.asset -->
    <record id="rule_asset_asset_company" model="ir.rule">
        <field name="name">Asset: Multi-Company Rule</field>
        <field name="model_id" ref="model_asset_asset"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- asset.category -->
    <record id="rule_asset_category_company" model="ir.rule">
        <field name="name">Asset Category: Multi-Company Rule</field>
        <field name="model_id" ref="model_asset_category"/>
