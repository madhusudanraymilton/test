<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form View ──────────────────────────────────────────────────── -->
    <record id="view_asset_category_form" model="ir.ui.view">
        <field name="name">asset.category.form</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <form string="Asset Category">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_assets"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-cubes">
                            <field name="asset_count" widget="statinfo" string="Assets"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger"
                           />
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Category Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="depreciation_method"/>
                            <field name="duration_months"/>
                            <field name="computation_method"/>
                            <field name="non_depreciable_pct"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Accounting Configuration" name="accounting">
                            <!-- <group>
                                <group string="Accounts">
                                    <field name="asset_id"/>
                                    <field name="account_depreciation_id"/>
                                    <field name="account_expense_id"/>
                                </group>
                                <group string="Journal">
                                    <field name="journal_id"/>
                                </group>
                            </group> -->
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── List View ──────────────────────────────────────────────────── -->
    <record id="view_asset_category_list" model="ir.ui.view">
        <field name="name">asset.category.list</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <list string="Asset Categories">
                <field name="name"/>
                <field name="depreciation_method"/>
                <field name="duration_months"/>
                <field name="computation_method"/>
                <field name="non_depreciable_pct" string="Non-Dep. %"/>
                <field name="asset_count" string="Assets"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

