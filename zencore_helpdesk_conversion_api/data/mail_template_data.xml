<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        mail_template_data.xml
        ──────────────────────
        Defines two lightweight notification templates.

        IMPORTANT DESIGN RULES (do not break):
          ① These templates are rendered and then used to populate
             mail.mail records via mail.mail.sudo().create({}).send().
             They are NEVER passed to message_post.
          ② No reply-to, no thread-id, no res_id linkage in the final
             mail.mail — these are one-way notification emails.
          ③ noupdate="1" — customer customisations to subject/body
             will survive module upgrades.
    -->
    <data noupdate="1">

        <!-- ─────────────────────────────────────────────────────────────────
             TEMPLATE 1 — Inbound Message → Notify Assigned Agent  (Section 2)

             Triggered: when the external portal posts a new message to
             POST /api/helpdesk/ticket/<id>/inbound_message.
             Recipient: ticket.user_id (the assigned support agent).
        ──────────────────────────────────────────────────────────────────── -->
        <record id="mail_template_inbound_notify_agent" model="mail.template">
            <field name="name">Helpdesk: New Inbound Message – Agent Notification</field>
            <field name="model_id" ref="helpdesk.model_helpdesk_ticket"/>

            <!-- Jinja2 expressions are evaluated at send time via generate_email() -->
            <field name="subject">New Message on Ticket #{{ object.id }}</field>

            <!-- <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; font-size: 14px; color: #333;">
    <p>Hello {{ object.user_id.name or 'Agent' }},</p>
    <p>
        You have received a new message on
        <strong>Ticket #{{ object.id }}: {{ object.name }}</strong>.
    </p>
    <p>Please log in to Odoo to review and respond.</p>
    <p style="color: #888; font-size: 12px;">
        This is an automated notification. Do not reply to this email.
    </p>
</div>
            ]]></field> -->


            <field name="body_html"><![CDATA[ 
            <div style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; line-height: 1.6;"> 
            <p>Dear {{ object.user_id.name or 'Support Agent' }},</p> 
            <p> A new customer message has been received for the following helpdesk ticket: </p> 
            <div style=" background-color: #f8f9fa; border: 1px solid #dcdcdc; border-radius: 6px; padding: 15px; margin: 15px 0; "> 
            <p style="margin: 0 0 8px 0;"> 
            <strong>Ticket:</strong> #{{ object.id }} — {{ object.name }} </p> 
            <p style="margin: 0 0 8px 0;"> <strong>Customer:</strong> {{ object.partner_id.name or 'N/A' }} </p> 
            <p style="margin: 0;"> <strong>Status:</strong> {{ object.stage_id.name or 'Open' }} </p> 
            </div> 
            <p> Please log in to the Helpdesk system to review the message and provide a response as soon as possible. </p> 
            <p style="margin-top: 30px;"> Regards,<br/> <strong>{{ user.company_id.name }}</strong> </p> 
            <hr style="border: none; border-top: 1px solid #e0e0e0; margin: 25px 0;"/> 
            <p style="font-size: 12px; color: #888888;"> This is an automated notification generated by Odoo Helpdesk. Please do not reply directly to this email. </p> 
            </div> ]]></field>

            <field name="auto_delete" eval="True"/>
            <!-- No email_to — recipient is injected by _notify_assigned_user_on_inbound() -->
        </record>

        <!-- ─────────────────────────────────────────────────────────────────
             TEMPLATE 2 — Outbound Reply → Notify Portal User  (Section 5)

             Triggered: when the assigned agent posts a chatter reply and
             message_post detects the author matches ticket.user_id.partner_id.
             Recipient: ticket.partner_id (the portal / end-customer).
        ──────────────────────────────────────────────────────────────────── -->
        <record id="mail_template_outbound_notify_portal" model="mail.template">
            <field name="name">Helpdesk: Outbound Reply – Portal User Notification</field>
            <field name="model_id" ref="helpdesk.model_helpdesk_ticket"/>

            <field name="subject">New Reply on Your Ticket #{{ object.id }}</field>

            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; font-size: 14px; color: #333;">
    <p>Hello {{ object.partner_id.name or 'Customer' }},</p>
    <p>
        You have received a new reply on
        <strong>Ticket #{{ object.id }}: {{ object.name }}</strong>.
    </p>
    <p>Please log in to the portal to review the latest conversation.</p>
    <p style="color: #888; font-size: 12px;">
        This is an automated notification. Do not reply to this email.
    </p>
</div>
            ]]></field>

            <field name="auto_delete" eval="True"/>
            <!-- No email_to — recipient is injected by _notify_portal_user_on_reply() -->
        </record>

    </data>
</odoo>