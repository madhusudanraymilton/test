<templates xml:space="preserve">

    <t
        t-name="zencore_helpdesk_chat.ComposerReply"
        t-inherit="mail.Composer"
        t-inherit-mode="extension"
    >

        <xpath
            expr="//div[contains(@class, 'o-mail-Composer-coreHeader')]"
            position="inside"
        >

            <div
                t-if="env.services.chatReply.replyMessage"
                class="border rounded p-2 mb-2 bg-light"
            >

                <div class="d-flex justify-content-between">

                    <div>

                        <div class="fw-bold text-primary small">
                            <t t-esc="env.services.chatReply.replyMessage.authorName"/>
                        </div>

                        <div class="small text-muted">
                            <t t-esc="env.services.chatReply.replyMessage.body"/>
                        </div>

                    </div>

                    <button
                        class="btn btn-sm btn-link text-danger"
                        t-on-click="() => env.services.chatReply.replyMessage = null"
                    >
                        <i class="fa fa-times"/>
                    </button>

                </div>

            </div>

        </xpath>

    </t>

</templates>