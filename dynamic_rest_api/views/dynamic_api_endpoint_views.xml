<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── FORM VIEW ─────────────────────────────────────────────────── -->
    <record id="view_dynamic_api_endpoint_form" model="ir.ui.view">
        <field name="name">dynamic.api.endpoint.form</field>
        <field name="model">dynamic.api.endpoint</field>
        <field name="arch" type="xml">
            <form string="API Endpoint">
                <header>
                    <button name="action_activate" string="Activate"
                            type="object" class="btn-success"
                            invisible="is_active"/>
                    <button name="action_deactivate" string="Deactivate"
                            type="object" class="btn-warning"
                            invisible="not is_active"/>
                    <button name="action_open_builder" string="Open Endpoint Builder"
                            type="object" class="btn-primary" icon="fa-magic"/>
                    <button name="action_view_logs" string="View Logs"
                            type="object" class="btn-secondary"
                            invisible="request_count == 0"/>
                    <field name="is_active" widget="statusbar"
                           statusbar_visible="0,1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs" type="object"
                                class="oe_stat_button" icon="fa-list">
                            <field name="request_count" widget="statinfo"
                                   string="Requests"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Inactive"
                            bg_color="bg-danger"
                            invisible="is_active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Sales Orders API"/></h1>
                    </div>

                    <group>
                        <group string="Target Model">
                            <field name="model_id"/>
                            <field name="model_name" readonly="1"/>
                            <field name="endpoint_path" readonly="1"/>
                        </group>
                        <group string="Authentication">
                            <field name="auth_type"/>
                            <field name="rate_limit"/>
                            <field name="cors_origins"/>
                        </group>
                    </group>

                    <group string="HTTP Methods">
                        <group>
                            <field name="allow_get"/>
                            <field name="allow_post"/>
                        </group>
                        <group>
                            <field name="allow_put"/>
                            <field name="allow_delete"/>
                        </group>
                    </group>

                    <group string="Options">
                        <field name="allow_create_field"/>
                    </group>

                    <field name="description" placeholder="Optional description…"/>

                    <notebook>
                        <page string="Exposed Fields" name="fields">
                            <field name="field_ids" context="{'default_endpoint_id': id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="field_id"
                                           domain="[('model_id', '=', parent.model_id)]"/>
                                    <field name="field_name" readonly="1"/>
                                    <!-- <field name="field_type" readonly="1"/> -->
                                    <field name="alias"/>
                                    <field name="is_readonly"/>
                                    <field name="is_custom" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="API Keys" name="keys"
                              invisible="auth_type != 'api_key'">
                            <field name="api_key_ids" widget="many2many_tags"/>
                            <p class="text-muted">
                                Leave empty to accept any valid active API key.
                            </p>
                        </page>
                        <page string="Statistics" name="stats">
                            <group>
                                <field name="request_count" readonly="1"/>
                                <field name="last_called" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── LIST VIEW ─────────────────────────────────────────────────── -->
    <record id="view_dynamic_api_endpoint_list" model="ir.ui.view">
        <field name="name">dynamic.api.endpoint.list</field>
        <field name="model">dynamic.api.endpoint</field>
        <field name="arch" type="xml">
            <list string="API Endpoints" decoration-muted="not is_active">
                <field name="name"/>
                <field name="model_name"/>
                <field name="endpoint_path"/>
                <field name="auth_type" widget="badge"
                       decoration-info="auth_type == 'session'"
                       decoration-warning="auth_type == 'public'"
                       decoration-success="auth_type == 'api_key'"/>
                <field name="allow_get" optional="show"/>
                <field name="allow_post" optional="show"/>
                <field name="allow_put" optional="show"/>
                <field name="allow_delete" optional="show"/>
                <field name="request_count"/>
                <field name="last_called"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ── SEARCH VIEW ───────────────────────────────────────────────── -->
    <record id="view_dynamic_api_endpoint_search" model="ir.ui.view">
        <field name="name">dynamic.api.endpoint.search</field>
        <field name="model">dynamic.api.endpoint</field>
        <field name="arch" type="xml">
            <search string="Search Endpoints">
                <field name="name"/>
                <field name="model_name"/>
                <field name="endpoint_path"/>
                <filter string="Active" name="active"
                        domain="[('is_active', '=', True)]"/>
                <filter string="Inactive" name="inactive"
                        domain="[('is_active', '=', False)]"/>
                <separator/>
                <filter string="Public" name="public"
                        domain="[('auth_type', '=', 'public')]"/>
                <filter string="API Key Auth" name="api_key"
                        domain="[('auth_type', '=', 'api_key')]"/>
              
                <filter string="Auth Type" name="group_auth"
                        context="{'group_by': 'auth_type'}"/>
                <filter string="Model" name="group_model"
                        context="{'group_by': 'model_name'}"/>
               
            </search>
        </field>
    </record>

    <!-- ── ACTION ────────────────────────────────────────────────────── -->
    <record id="action_dynamic_api_endpoint" model="ir.actions.act_window">
        <field name="name">API Endpoints</field>
        <field name="res_model">dynamic.api.endpoint</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_dynamic_api_endpoint_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first dynamic REST API endpoint
            </p>
            <p>
                Select an Odoo model, choose which fields to expose, set
                authentication, and your endpoint is live immediately.
            </p>
        </field>
    </record>

    <!-- ── CLIENT ACTION for EndpointBuilder OWL component ──────────── -->
    <record id="action_endpoint_builder_client" model="ir.actions.client">
        <field name="name">Endpoint Builder</field>
        <field name="tag">dynamic_rest_api.endpoint_builder</field>
    </record>
</odoo>